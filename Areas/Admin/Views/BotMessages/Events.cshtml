@model IEnumerable<ARCompletions.Domain.BotIncomingEvent>
@{
    ViewData["Title"] = "Bot Incoming Events";
}

<h1>Bot 訊息輸入事件</h1>

@{
    int ps = ViewBag.PageSize ?? 50;
}

<form method="get" class="row g-2 mb-2">
    <div class="col-auto">
        <input name="conversationId" value="@ViewBag.ConversationId" placeholder="ConversationId" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <input name="userId" value="@ViewBag.UserId" placeholder="LineUserId" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <input name="messageType" value="@ViewBag.MessageType" placeholder="MessageType" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="25" selected="@(ps == 25 ? "selected" : null)">25</option>
            <option value="50" selected="@(ps == 50 ? "selected" : null)">50</option>
            <option value="100" selected="@(ps == 100 ? "selected" : null)">100</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-primary" type="submit">搜尋</button>
    </div>
</form>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>EventRowId</th>
            <th>ConversationId</th>
            <th>SourceType</th>
            <th>LineUserId</th>
            <th>MessageType</th>
            <th>EventType</th>
            <th>ReceivedAt</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.EventRowId</td>
            <td>@item.ConversationId</td>
            <td>@item.SourceType</td>
            <td>@item.LineUserId</td>
            <td>@item.MessageType</td>
            <td>@item.EventType</td>
            <td>@item.ReceivedAt</td>
        </tr>
    }
    </tbody>
</table>

@{
    long total = ViewBag.TotalCount ?? 0L;
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 50;
    var totalPages = (int)System.Math.Ceiling(total / (double)pageSize);
}

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            <li class="page-item @(page<=1?"disabled":"")">
                <a class="page-link" href="?page=@(page-1)&pageSize=@pageSize&conversationId=@ViewBag.ConversationId&userId=@ViewBag.UserId&messageType=@ViewBag.MessageType">上一頁</a>
            </li>
            @for (var p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p==page?"active":"")">
                    <a class="page-link" href="?page=@p&pageSize=@pageSize&conversationId=@ViewBag.ConversationId&userId=@ViewBag.UserId&messageType=@ViewBag.MessageType">@p</a>
                </li>
            }
            <li class="page-item @(page>=totalPages?"disabled":"")">
                <a class="page-link" href="?page=@(page+1)&pageSize=@pageSize&conversationId=@ViewBag.ConversationId&userId=@ViewBag.UserId&messageType=@ViewBag.MessageType">下一頁</a>
            </li>
        </ul>
    </nav>
}
