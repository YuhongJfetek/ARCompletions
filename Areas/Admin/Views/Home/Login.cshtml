@{
    Layout = null;
}
<html>
<head>
    <meta charset="utf-8" />
    <title>管理員登入</title>
</head>
<body>
    <h1>管理員登入</h1>
    <form method="post" action="/Admin/Home/Login">
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
        <div>
            <label>使用者名稱</label>
            <input name="username" />
        </div>
        <div>
            <label>密碼</label>
            <input name="password" type="password" />
        </div>
        <div>
            <button type="submit">登入</button>
        </div>
    </form>
    @if (!ViewContext.ViewData.ModelState.IsValid)
    {
        <div style="color:red">登入失敗：帳號或密碼錯誤</div>
    }
</body>
</html>
