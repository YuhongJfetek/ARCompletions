@model ARCompletions.Areas.Admin.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = ViewData["Title"] ?? "總部後台首頁";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <strong>Debug:</strong>
    <div>IsAuthenticated: @ViewBag.IsAuthenticated</div>
    <div>UserName: @ViewBag.UserName</div>
    <div>IsPlatformAuthorized: @ViewBag.IsPlatformAuthorized</div>
    <div>Claims:</div>
    <pre style="max-height:200px;overflow:auto;background:#f8f9fa;padding:8px;border-radius:6px;">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.Claims, new System.Text.Json.JsonSerializerOptions{WriteIndented=true}))</pre>
</div>

<ul>
    <li>廠商總數：@Model.VendorCount</li>
    <li>啟用廠商數：@Model.ActiveVendorCount</li>
    <li>對話總數：@Model.ConversationCount</li>
    <li>FAQ 總數：@Model.FaqCount</li>
    <li>FAQ 候選總數：@Model.FaqCandidateCount</li>
    <li>Embedding 任務總數：@Model.EmbeddingJobCount</li>
    <li>AI FAQ 分析任務總數：@Model.AiFaqAnalysisJobCount</li>
</ul>

<p>後續可以在此加入圖表、連結到各管理頁面（廠商管理、對話紀錄、FAQ 管理、Embedding 管理等）。</p>
