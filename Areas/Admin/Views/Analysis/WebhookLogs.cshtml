@model System.Collections.Generic.List<ARCompletions.Data.LineEventLog>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Webhook 日誌</h2>

<form method="get" asp-area="Admin" asp-controller="Analysis" asp-action="WebhookLogs" class="row g-2 mb-3">
    <div class="col-auto">
        <input type="text" name="userId" value="@(ViewData["userId"] ?? "")" class="form-control" placeholder="userId" />
    </div>
    <div class="col-auto">
        <input type="text" name="eventType" value="@(ViewData["eventType"] ?? "")" class="form-control" placeholder="eventType" />
    </div>
    <div class="col-auto">
        <input type="number" name="skip" value="@(ViewData["skip"] ?? 0)" class="form-control" style="width:100px" />
    </div>
    <div class="col-auto">
        <input type="number" name="take" value="@(ViewData["take"] ?? 50)" class="form-control" style="width:100px" />
    </div>
    <div class="col-auto">
        <button class="btn btn-outline-primary" type="submit">查詢</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>LineUserId</th>
            <th>EventType</th>
            <th>MessageType</th>
            <th>Text</th>
            <th>CreatedAt</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in Model)
    {
        <tr>
            <td>@l.Id</td>
            <td>@l.LineUserId</td>
            <td>@l.EventType</td>
            <td>@l.MessageType</td>
            <td>@l.Text</td>
            <td>@l.CreatedAt.ToLocalTime().ToString("g")</td>
        </tr>
    }
    </tbody>
</table>