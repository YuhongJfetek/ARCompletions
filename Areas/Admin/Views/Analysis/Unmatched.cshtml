@model ARCompletions.Areas.Admin.Models.UnmatchedIndexViewModel

@{
    Layout = null;
}
<html>
<head>
    <meta charset="utf-8" />
    <title>未命中問題列表</title>
    <style>
        table { border-collapse: collapse; width: 100%; }
        th, td { border: 1px solid #ddd; padding: 8px; }
        th { background: #f2f2f2; }
    </style>
</head>
<body>
    <h1>未命中問題列表</h1>

    <form method="get" action="/Admin/Analysis/Unmatched">
        <input type="text" name="q" placeholder="搜尋問題文字" value="@Model.Query" />
        <select name="pageSize">
            @foreach (var ps in Model.PageSizeOptions) {
                @if (ps == Model.PageSize) {
                    <option value="@ps" selected>@ps</option>
                } else {
                    <option value="@ps">@ps</option>
                }
            }
        </select>
        <button type="submit">搜尋</button>
        <a href="/Admin/Analysis/UnmatchedExport?q=@(System.Net.WebUtility.UrlEncode(Model.Query ?? ""))">匯出 CSV</a>
    </form>

    <table>
        <thead>
            <tr><th>Id</th><th>Query</th><th>Source</th><th>CreatedAt</th></tr>
        </thead>
        <tbody>
        @foreach (var it in Model.Items) {
            <tr>
                <td>@it.Id</td>
                <td>@it.Query</td>
                <td>@it.Source</td>
                <td>@System.DateTimeOffset.FromUnixTimeSeconds(it.CreatedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
            </tr>
        }
        </tbody>
    </table>

    <div>
        <span>第 @Model.Page / @Model.TotalPages 頁</span>
        @if (Model.Page > 1) {
            <a href="/Admin/Analysis/Unmatched?page=@(Model.Page-1)&pageSize=@Model.PageSize&q=@(System.Net.WebUtility.UrlEncode(Model.Query ?? ""))">上一頁</a>
        }
        @if (Model.Page < Model.TotalPages) {
            <a href="/Admin/Analysis/Unmatched?page=@(Model.Page+1)&pageSize=@Model.PageSize&q=@(System.Net.WebUtility.UrlEncode(Model.Query ?? ""))">下一頁</a>
        }
    </div>

</body>
</html>
