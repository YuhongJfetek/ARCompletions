@model ARCompletions.Areas.Admin.Models.AnalysisIndexViewModel

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>分析工作</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row mb-3">
    <div class="col-md-8">
        <form asp-area="Admin" asp-controller="Analysis" asp-action="Index" method="get" class="form-inline">
            <div class="input-group">
                <input type="text" name="searchQuery" value="@Model.SearchQuery" class="form-control" placeholder="搜尋 id、params、結果..." />
                <select name="filterType" class="form-select">
                    <option value="">所有類型</option>
                    @foreach (var t in Model.Types)
                    {
                        <option value="@t" @(t == Model.FilterType ? "selected" : "")>@t</option>
                    }
                </select>
                <select name="filterStatus" class="form-select">
                    <option value="">所有狀態</option>
                    @foreach (var s in Model.Statuses)
                    {
                        <option value="@s" @(s == Model.FilterStatus ? "selected" : "")>@s</option>
                    }
                </select>
                <input type="date" name="startDate" value="@(Model.StartDate.HasValue ? Model.StartDate.Value.ToString("yyyy-MM-dd") : "")" class="form-control" />
                <input type="date" name="endDate" value="@(Model.EndDate.HasValue ? Model.EndDate.Value.ToString("yyyy-MM-dd") : "")" class="form-control" />
                <input type="text" name="jsonKey" value="@Model.JsonKey" class="form-control" placeholder="JSON 鍵" />
                <input type="text" name="jsonValue" value="@Model.JsonValue" class="form-control" placeholder="JSON 值" />
                <select name="pageSize" class="form-select">
                    @foreach (var ps in Model.PageSizeOptions)
                    {
                        <option value="@ps" @(ps == Model.PageSize ? "selected" : "")>@ps</option>
                    }
                </select>
                <button class="btn btn-outline-primary" type="submit">篩選</button>
            </div>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <form asp-area="Admin" asp-controller="Analysis" asp-action="Jobs" method="post">
            <div class="mb-3">
                <label for="body">手動工作參數 (JSON)</label>
                <textarea id="body" name="body" class="form-control" rows="3">{}</textarea>
            </div>
            <button class="btn btn-primary" type="submit">建立工作</button>
            @Html.AntiForgeryToken()
        </form>
    </div>
</div>

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Id</th>
            <th>類型</th>
            <th>狀態</th>
            <th>進度</th>
            <th>建立時間</th>
            <th>結果</th>
            <th>錯誤</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var j in Model.Jobs)
    {
        <tr>
            <td><a asp-area="Admin" asp-controller="Analysis" asp-action="Details" asp-route-id="@j.Id">@j.Id</a></td>
            <td>@j.Type</td>
            <td>@j.Status</td>
            <td>@j.Progress %</td>
            <td>@DateTimeOffset.FromUnixTimeSeconds(j.CreatedAt).ToLocalTime().ToString("g")</td>
            <td>@j.ResultSummary</td>
            <td>@j.Error</td>
            <td>
                <form asp-area="Admin" asp-controller="Analysis" asp-action="Reanalyze" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@j.Id" />
                    @Html.AntiForgeryToken()
                    <button class="btn btn-sm btn-secondary" type="submit">重新分析</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<nav aria-label="Page navigation">
  <ul class="pagination">
        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
            <a class="page-link" asp-area="Admin" asp-controller="Analysis" asp-action="Index" asp-route-page="@(Model.Page-1)" asp-route-pageSize="@Model.PageSize" asp-route-searchQuery="@Model.SearchQuery" asp-route-filterType="@Model.FilterType" asp-route-filterStatus="@Model.FilterStatus">上一頁</a>
        </li>
        @for (int p = 1; p <= Model.TotalPages; p++)
        {
            <li class="page-item @(p == Model.Page ? "active" : "")"><a class="page-link" asp-area="Admin" asp-controller="Analysis" asp-action="Index" asp-route-page="@p" asp-route-pageSize="@Model.PageSize" asp-route-searchQuery="@Model.SearchQuery" asp-route-filterType="@Model.FilterType" asp-route-filterStatus="@Model.FilterStatus">@p</a></li>
        }
        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-area="Admin" asp-controller="Analysis" asp-action="Index" asp-route-page="@(Model.Page+1)" asp-route-pageSize="@Model.PageSize" asp-route-searchQuery="@Model.SearchQuery" asp-route-filterType="@Model.FilterType" asp-route-filterStatus="@Model.FilterStatus">下一頁</a>
        </li>
  </ul>
</nav>
