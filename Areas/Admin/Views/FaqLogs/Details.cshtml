@model ARCompletions.Domain.FaqLog

@{
    ViewData["Title"] = "FAQ Log Details";
}

<h1>FAQ Log Details</h1>

<dl class="row">
    <dt class="col-sm-3">時間</dt>
    <dd class="col-sm-9">@System.DateTimeOffset.FromUnixTimeSeconds(Model.OperatedAt).UtcDateTime.ToString("yyyy-MM-dd HH:mm")</dd>

    <dt class="col-sm-3">廠商</dt>
    <dd class="col-sm-9">@((ViewBag.Faq as ARCompletions.Domain.Faq)?.VendorId ?? Model.VendorId)</dd>

    <dt class="col-sm-3">操作者</dt>
    <dd class="col-sm-9">@Model.OperatedByType / @Model.OperatedById</dd>

    <dt class="col-sm-3">動作</dt>
    <dd class="col-sm-9">@Model.ActionType</dd>

    <dt class="col-sm-3">目標 FAQ</dt>
    <dd class="col-sm-9">@Model.FaqId</dd>

    <dt class="col-sm-3">變更前</dt>
    <dd class="col-sm-9"><pre>@Model.BeforeJson</pre></dd>

    <dt class="col-sm-3">變更後</dt>
    <dd class="col-sm-9"><pre>@Model.AfterJson</pre></dd>
</dl>

<a asp-area="Admin" asp-controller="FaqLogs" asp-action="Index" class="btn btn-secondary">Back</a>
@{
    var faq = ViewBag.Faq as ARCompletions.Domain.Faq;
}

@if (faq != null)
{
    <h4>Current FAQ</h4>
    <div class="card mb-3">
        <div class="card-body">
            <p><strong>Question:</strong> @faq.Question</p>
            <p><strong>Answer:</strong> @faq.Answer</p>
            <p><strong>Status:</strong> @faq.Status</p>
        </div>
    </div>
}

