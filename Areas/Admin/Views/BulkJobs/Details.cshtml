@model ARCompletions.Domain.BulkJob
@{
    ViewData["Title"] = "Bulk Job Details";
    var logs = ViewBag.Logs as IEnumerable<ARCompletions.Domain.AuditLog> ?? Enumerable.Empty<ARCompletions.Domain.AuditLog>();
}

<h1>Bulk Job Details</h1>

<table class="table table-bordered">
    <tr><th>Id</th><td>@Model.Id</td></tr>
    <tr><th>Action</th><td>@Model.Action</td></tr>
    <tr><th>Initiator</th><td>@Model.Initiator</td></tr>
    <tr><th>Total</th><td>@Model.TotalCount</td></tr>
    <tr><th>Processed</th><td>@Model.ProcessedCount</td></tr>
    <tr><th>Status</th><td>@Model.Status</td></tr>
    <tr><th>Created At</th><td>@(Model.CreatedAt==0?"-":DateTimeOffset.FromUnixTimeSeconds(Model.CreatedAt).UtcDateTime.ToString("yyyy-MM-dd HH:mm"))</td></tr>
    <tr><th>Updated At</th><td>@(Model.UpdatedAt==null?"-":DateTimeOffset.FromUnixTimeSeconds(Model.UpdatedAt.Value).UtcDateTime.ToString("yyyy-MM-dd HH:mm"))</td></tr>
    <tr><th>Filter</th><td><pre>@Model.FilterJson</pre></td></tr>
    <tr><th>Error</th><td>@Model.ErrorMessage</td></tr>
</table>

<h4>Audit Logs</h4>
<table class="table table-sm table-striped">
    <thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Payload</th></tr></thead>
    <tbody>
    @foreach (var l in logs)
    {
        <tr>
            <td>@DateTimeOffset.FromUnixTimeSeconds(l.Timestamp).UtcDateTime.ToString("yyyy-MM-dd HH:mm")</td>
            <td>@l.Actor</td>
            <td>@l.Action</td>
            <td>@l.Payload</td>
        </tr>
    }
    </tbody>
</table>

<p>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</p>
