@model ARCompletions.Domain.VendorStaffUser

<h2>刪除 廠商人員</h2>

<p>Are you sure you want to delete this staff user?</p>

<dl class="row">
    <dt class="col-sm-3">Line 使用者 Id</dt>
    <dd class="col-sm-9">@Model.LineUserId</dd>
    <dt class="col-sm-3">姓名</dt>
    <dd class="col-sm-9">@Model.Name</dd>
</dl>

<form asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">刪除</button>
    <a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
