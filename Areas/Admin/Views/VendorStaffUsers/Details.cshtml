@model ARCompletions.Domain.VendorStaffUser

<h2>廠商人員詳情</h2>

<dl class="row">
    <dt class="col-sm-3">Line 使用者 Id</dt>
    <dd class="col-sm-9">@Model.LineUserId</dd>

    <dt class="col-sm-3">姓名</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">角色</dt>
    <dd class="col-sm-9">@Model.Role</dd>

    <dt class="col-sm-3">啟用</dt>
    <dd class="col-sm-9">@Model.IsActive</dd>
</dl>

<p>
    <a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Edit" asp-route-id="@Model.Id">編輯</a> |
    <a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Index">回到列表</a>
</p>
