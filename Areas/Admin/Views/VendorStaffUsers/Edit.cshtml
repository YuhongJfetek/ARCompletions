@model ARCompletions.Domain.VendorStaffUser

<h2>Edit Vendor Staff User</h2>

<form asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Edit" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="form-group">
        <label>LineUserId</label>
        <input class="form-control" name="LineUserId" value="@Model.LineUserId" />
    </div>
    <div class="form-group">
        <label>Name</label>
        <input class="form-control" name="Name" value="@Model.Name" />
    </div>
    <div class="form-group">
        <label>Role</label>
        <input class="form-control" name="Role" value="@Model.Role" />
    </div>
    <div class="form-group">
        <label>IsActive</label>
        <input type="checkbox" name="IsActive" @(Model.IsActive ? "checked" : "") />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
