@model IEnumerable<ARCompletions.Domain.VendorStaffUser>

<h2>廠商人員</h2>

<p><a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Create">Create New</a></p>

<table class="table">
    <thead>
        <tr>
            <th>LineUserId</th>
            <th>Name</th>
            <th>Role</th>
            <th>IsActive</th>
            <th>CreatedAt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model) {
        <tr>
            <td>@item.LineUserId</td>
            <td>@item.Name</td>
            <td>@item.Role</td>
            <td>@item.IsActive</td>
            <td>@item.CreatedAt</td>
            <td>
                <a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-area="Admin" asp-controller="VendorStaffUsers" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
