@model ARCompletions.Domain.BotFaqAlias
@{
    ViewData["Title"] = "編輯 FAQ Alias";
}

<h1>編輯 FAQ Alias</h1>

<form asp-area="Admin" asp-controller="BotFaqAliases" asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="AliasId" />
    <div class="mb-2">
        <label asp-for="Term" class="form-label"></label>
        <input asp-for="Term" class="form-control" />
        <span asp-validation-for="Term" class="text-danger"></span>
    </div>
    <div class="mb-2">
        <label asp-for="Mode" class="form-label"></label>
        <input asp-for="Mode" class="form-control" />
    </div>
    <div class="mb-2">
        <label asp-for="Synonyms" class="form-label"></label>
        <textarea asp-for="Synonyms" class="form-control" rows="2"></textarea>
    </div>
    <div class="mb-2">
        <label asp-for="FaqIds" class="form-label"></label>
        <textarea asp-for="FaqIds" class="form-control" rows="2"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="Enabled" class="form-check-input" />
        <label asp-for="Enabled" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-primary">儲存</button>
    <a asp-area="Admin" asp-controller="BotFaqAliases" asp-action="Index" class="btn btn-secondary ms-2">取消</a>
</form>
