@model IEnumerable<ARCompletions.Domain.BotFaqAlias>
@{
    ViewData["Title"] = "Bot FAQ Alias 管理";
    long total = ViewBag.TotalCount ?? 0L;
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 25;
    var q = ViewBag.Query as string;
    var mode = ViewBag.Mode as string;
    bool? enabled = ViewBag.Enabled as bool?;
    var totalPages = (int)System.Math.Ceiling(total / (double)pageSize);
}

<h1>Bot FAQ Alias 管理</h1>

<form method="get" class="row g-2 mb-2">
    <div class="col-auto">
        <input name="q" value="@q" placeholder="Term" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <input name="mode" value="@mode" placeholder="Mode (direct / disambiguation)" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <select name="enabled" class="form-select form-select-sm">
            <option value="">全部</option>
            <option value="true" @(enabled==true?"selected":"")>啟用</option>
            <option value="false" @(enabled==false?"selected":"")>停用</option>
        </select>
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="25" @(pageSize==25?"selected":"")>25</option>
            <option value="50" @(pageSize==50?"selected":"")>50</option>
            <option value="100" @(pageSize==100?"selected":"")>100</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-primary" type="submit">搜尋</button>
        <a asp-area="Admin" asp-controller="BotFaqAliases" asp-action="Create" class="btn btn-sm btn-success ms-2">新增 Alias</a>
    </div>
</form>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>Term</th>
            <th>Mode</th>
            <th>Enabled</th>
            <th>CreatedAt</th>
            <th>UpdatedAt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Term</td>
            <td>@item.Mode</td>
            <td>@(item.Enabled ? "是" : "否")</td>
            <td>@item.CreatedAt</td>
            <td>@item.UpdatedAt</td>
            <td>
                <a asp-area="Admin" asp-controller="BotFaqAliases" asp-action="Edit" asp-route-id="@item.AliasId" class="btn btn-sm btn-secondary">編輯</a>
                <a asp-area="Admin" asp-controller="BotFaqAliases" asp-action="Details" asp-route-id="@item.AliasId" class="btn btn-sm btn-outline-secondary">檢視</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            <li class="page-item @(page<=1?"disabled":"")">
                <a class="page-link" href="?page=@(page-1)&amp;pageSize=@pageSize&amp;q=@q&amp;mode=@mode&amp;enabled=@enabled">上一頁</a>
            </li>
            @for (var p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p==page?"active":"")">
                    <a class="page-link" href="?page=@p&amp;pageSize=@pageSize&amp;q=@q&amp;mode=@mode&amp;enabled=@enabled">@p</a>
                </li>
            }
            <li class="page-item @(page>=totalPages?"disabled":"")">
                <a class="page-link" href="?page=@(page+1)&amp;pageSize=@pageSize&amp;q=@q&amp;mode=@mode&amp;enabled=@enabled">下一頁</a>
            </li>
        </ul>
    </nav>
}
