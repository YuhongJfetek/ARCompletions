@model System.Collections.Generic.List<ARCompletions.Data.ChatMessage>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>聊天記錄</h2>

<p>總筆數：@ViewData["TotalCount"]</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Id</th>
            <th>UserId</th>
            <th>Role</th>
            <th>Content</th>
            <th>CreatedAt</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var m in Model)
    {
        <tr>
            <td>@m.Id</td>
            <td>@m.UserId</td>
            <td>@m.Role</td>
            <td>@m.Content</td>
            <td>@DateTimeOffset.FromUnixTimeSeconds(m.CreatedAt).ToLocalTime().ToString("g")</td>
        </tr>
    }
    </tbody>
</table>

<nav>
    <ul class="pagination">
        @{ var page = (int)ViewData["Page"]; var pageSize = (int)ViewData["PageSize"]; var total = (int)ViewData["TotalCount"]; var totalPages = (int)Math.Ceiling(total / (double)pageSize); }
        <li class="page-item @(page <= 1 ? "disabled" : "")"><a class="page-link" asp-area="Admin" asp-controller="Chat" asp-action="Index" asp-route-page="@(page-1)" asp-route-pageSize="@pageSize">上一頁</a></li>
        @for (int p = 1; p <= totalPages; p++) {
            <li class="page-item @(p == page ? "active" : "")"><a class="page-link" asp-area="Admin" asp-controller="Chat" asp-action="Index" asp-route-page="@p" asp-route-pageSize="@pageSize">@p</a></li>
        }
        <li class="page-item @(page >= totalPages ? "disabled" : "")"><a class="page-link" asp-area="Admin" asp-controller="Chat" asp-action="Index" asp-route-page="@(page+1)" asp-route-pageSize="@pageSize">下一頁</a></li>
    </ul>
</nav>