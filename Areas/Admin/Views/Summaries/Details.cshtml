@model ARCompletions.Domain.AiFaqAnalysisJob
@{
    ViewData["Title"] = "Summary Details";
    var candidates = ViewBag.Candidates as System.Collections.Generic.List<ARCompletions.Domain.FaqCandidate> ?? new System.Collections.Generic.List<ARCompletions.Domain.FaqCandidate>();
}

<h1>Summary Job — @Model.JobNo</h1>
<table class="table table-bordered mb-3">
    <tr><th>Vendor</th><td>@Model.VendorId</td></tr>
    <tr><th>Status</th><td>@Model.Status</td></tr>
    <tr><th>Conversations</th><td>@Model.ConversationCount</td></tr>
    <tr><th>Messages</th><td>@Model.MessageCount</td></tr>
    <tr><th>Candidates</th><td>@Model.CandidateCount</td></tr>
    <tr><th>CreatedAt</th><td>@(DateTimeOffset.FromUnixTimeSeconds(Model.CreatedAt).UtcDateTime)</td></tr>
</table>

<h3>Top Candidates</h3>
<table class="table table-sm">
    <thead><tr><th>Question</th><th>Confidence</th><th>Suggested Category</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach(var c in candidates)
    {
        <tr>
            <td>@c.Question</td>
            <td>@(c.ConfidenceScore?.ToString("0.00") ?? "-")</td>
            <td>@c.SuggestedCategory</td>
            <td><a asp-area="Admin" asp-controller="KnowledgeCandidates" asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">View</a></td>
        </tr>
    }
    </tbody>
</table>
