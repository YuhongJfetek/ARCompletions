@model IEnumerable<ARCompletions.Domain.AiFaqAnalysisJob>
@{
    ViewData["Title"] = "Summaries";
    int page = ViewBag.Page ?? 1; int pageSize = ViewBag.PageSize ?? 25; long total = ViewBag.TotalCount ?? 0L;
}

<h1>摘要（AI FAQ 分析任務）</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <label class="form-label">開始日期</label>
        <input type="date" name="dateFrom" class="form-control" value="@(ViewBag.DateFrom ?? "")" />
    </div>
    <div class="col-auto">
        <label class="form-label">結束日期</label>
        <input type="date" name="dateTo" class="form-control" value="@(ViewBag.DateTo ?? "")" />
    </div>
    <div class="col-auto align-self-end">
        <button class="btn btn-secondary">篩選</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr><th>JobNo</th><th>Vendor</th><th>Status</th><th>Convos</th><th>Candidates</th><th>CreatedAt</th><th></th></tr>
    </thead>
    <tbody>
    @foreach(var j in Model)
    {
        <tr>
            <td>@j.JobNo</td>
            <td>@j.VendorId</td>
            <td>@j.Status</td>
            <td>@j.ConversationCount</td>
            <td>@j.CandidateCount</td>
            <td>@(DateTimeOffset.FromUnixTimeSeconds(j.CreatedAt).UtcDateTime)</td>
            <td>
                <a asp-action="Details" asp-route-id="@j.Id" class="btn btn-sm btn-secondary">檢視</a>
                <a asp-action="ExportSummary" asp-route-id="@j.Id" class="btn btn-sm btn-outline-success ms-2">Download Summary</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<div>共 @total 筆</div>
