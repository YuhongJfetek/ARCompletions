@model IEnumerable<ARCompletions.Domain.Conversation>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "對話列表 (總部)";
}

<h1>對話列表（總部）</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <label class="form-label">廠商</label>
        <select name="vendorId" class="form-select" asp-items="(SelectList)ViewBag.Vendors">
            <option value="">(全部)</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">篩選</label>
        <select name="filter" class="form-select">
            <option value="" @(ViewBag.ActiveFilter == null ? "selected" : "")>(全部)</option>
            <option value="matched" @(ViewBag.ActiveFilter == "matched" ? "selected" : "")>已匹配</option>
            <option value="low_confidence" @(ViewBag.ActiveFilter == "low_confidence" ? "selected" : "")>低信心</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">Confidence 閾值</label>
        <input type="number" step="0.01" min="0" max="1" name="confidenceThreshold" class="form-control" value="@(ViewBag.ConfidenceThreshold ?? "")" />
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-secondary">篩選</button>
    </div>
    <div class="col-auto align-self-end">
        <a class="btn btn-outline-success" href="@Url.Action("ExportCsv", "Conversations", new { area = "Admin", vendorId = ViewContext.HttpContext.Request.Query["vendorId"], filter = ViewContext.HttpContext.Request.Query["filter"], confidenceThreshold = ViewBag.ConfidenceThreshold })">匯出 CSV</a>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Vendor</th>
            <th>平台</th>
            <th>Channel</th>
            <th>UserId</th>
            <th>名稱</th>
            <th>訊息數</th>
            <th>狀態</th>
            <th>Route</th>
            <th>Matched FAQ</th>
            <th>Confidence</th>
            <th>開始時間</th>
            <th>最後訊息時間</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        var summary = (ViewBag.MessageSummary as System.Collections.Generic.Dictionary<string, dynamic>) ?? new System.Collections.Generic.Dictionary<string, dynamic>();
        var s = summary.ContainsKey(item.Id) ? summary[item.Id] : null;
        <tr>
            <td>@item.VendorId</td>
            <td>@item.Platform</td>
            <td>@item.Channel</td>
            <td>@item.ExternalUserId</td>
            <td>@item.DisplayName</td>
            <td>@item.MessageCount</td>
            <td>@item.Status</td>
            <td>@(s?.Route ?? "-")</td>
            <td>@(s?.MatchedFaqId ?? "-")</td>
            <td>@(s?.Confidence != null ? ((double)s.Confidence).ToString("0.00") : "-")</td>
            <td>@item.StartedAt</td>
            <td>@item.LastMessageAt</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">檢視</a>
            </td>
        </tr>
    }
    </tbody>
</table>
