@model ARCompletions.Domain.FaqQueryLog
@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>FAQ Query Log Details</h2>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">CreatedAt</dt>
    <dd class="col-sm-10">@DateTimeOffset.FromUnixTimeSeconds(Model.CreatedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>

    <dt class="col-sm-2">MessageResultId</dt>
    <dd class="col-sm-10">@Model.MessageResultId</dd>

    <dt class="col-sm-2">QueryText</dt>
    <dd class="col-sm-10">@Model.QueryText</dd>

    <dt class="col-sm-2">MatchedFaqId</dt>
    <dd class="col-sm-10">@Model.MatchedFaqId</dd>

    <dt class="col-sm-2">Confidence</dt>
    <dd class="col-sm-10">@(Model.Confidence?.ToString("F3") ?? "-")</dd>

    <dt class="col-sm-2">Details (JSON)</dt>
    <dd class="col-sm-10">
        <div class="mb-2"><button id="copyDetails" class="btn btn-sm btn-outline-secondary">Copy</button></div>
        <pre id="detailsPre" style="max-height:480px;overflow:auto;white-space:pre-wrap;">@Model.DetailsJson</pre>
    </dd>
</dl>

@section Scripts {
    <script>
        document.getElementById('copyDetails')?.addEventListener('click', function(){
            var txt = document.getElementById('detailsPre')?.innerText || '';
            if (navigator.clipboard) navigator.clipboard.writeText(txt).then(function(){ alert('Copied'); });
        });
    </script>
}
