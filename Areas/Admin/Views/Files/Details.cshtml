@model dynamic
@{
    ViewData["Title"] = "檔案詳細";
}

<h2>檔案詳細（範本）</h2>

<dl class="row">
    <dt class="col-sm-2">Id</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">檔名</dt>
    <dd class="col-sm-10">@Model.FileName</dd>

    <dt class="col-sm-2">狀態</dt>
    <dd class="col-sm-10">@Model.Status</dd>
</dl>

<a asp-area="Admin" asp-controller="Files" asp-action="Index" class="btn btn-secondary">Back</a>
