@model ARCompletions.Domain.MessageRoute

<h2>編輯 訊息路由</h2>

<form asp-area="Admin" asp-controller="MessageRoutes" asp-action="Edit" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="form-group">
        <label>Route</label>
        <input class="form-control" name="Route" value="@Model.Route" />
    </div>
    <div class="form-group">
        <label>Reason</label>
        <input class="form-control" name="Reason" value="@Model.Reason" />
    </div>
    <div class="form-group">
        <label>MatchedFaqId</label>
        <input class="form-control" name="MatchedFaqId" value="@Model.MatchedFaqId" />
    </div>
    <div class="form-group">
        <label>MatchedScore</label>
        <input class="form-control" name="MatchedScore" value="@Model.MatchedScore" />
    </div>
    <div class="form-group">
        <label>LlmEnabled</label>
        <input type="checkbox" name="LlmEnabled" @(Model.LlmEnabled ? "checked" : "") />
    </div>
    <div class="form-group">
        <label>NeedsHandoff</label>
        <input type="checkbox" name="NeedsHandoff" @(Model.NeedsHandoff ? "checked" : "") />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
