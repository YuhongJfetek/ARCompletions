@model ARCompletions.Domain.MessageRoute

<h2>Delete Message Route</h2>

<p>Are you sure you want to delete this message route?</p>

<dl class="row">
    <dt class="col-sm-3">Route</dt>
    <dd class="col-sm-9">@Model.Route</dd>
    <dt class="col-sm-3">MatchedFaqId</dt>
    <dd class="col-sm-9">@Model.MatchedFaqId</dd>
</dl>

<form asp-area="Admin" asp-controller="MessageRoutes" asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-area="Admin" asp-controller="MessageRoutes" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
