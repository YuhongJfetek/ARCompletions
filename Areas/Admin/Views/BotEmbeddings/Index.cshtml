@model IEnumerable<ARCompletions.Domain.BotFaqEmbedding>
@{
    ViewData["Title"] = "Bot Embeddings";
}

<h1>Bot Embeddings</h1>

@{
    int ps = ViewBag.PageSize ?? 25;
}

<form method="get" class="row g-2 mb-2">
    <div class="col-auto">
        <input name="faqId" value="@ViewBag.FaqId" placeholder="FaqId" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <select name="isActive" class="form-select form-select-sm">
            <option value="">全部狀態</option>
            <option value="true" @(ViewBag.IsActive==true?"selected":"")>啟用</option>
            <option value="false" @(ViewBag.IsActive==false?"selected":"")>停用</option>
        </select>
    </div>
    <div class="col-auto">
        <input name="provider" value="@ViewBag.Provider" placeholder="Provider" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <input name="model" value="@ViewBag.Model" placeholder="Model" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <select name="pageSize" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="25" @(ps==25?"selected":"")>25</option>
            <option value="50" @(ps==50?"selected":"")>50</option>
            <option value="100" @(ps==100?"selected":"")>100</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-primary" type="submit">搜尋</button>
    </div>
</form>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>EmbeddingId</th>
            <th>FaqId</th>
            <th>Provider</th>
            <th>Model</th>
            <th>IsActive</th>
            <th>CreatedAt</th>
            <th>RebuiltAt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.EmbeddingId</td>
            <td>@item.FaqId</td>
            <td>@item.EmbeddingProvider</td>
            <td>@item.EmbeddingModel</td>
            <td>@(item.IsActive ? "是" : "否")</td>
            <td>@item.CreatedAt</td>
            <td>@item.RebuiltAt</td>
            <td>
                <a asp-area="Admin" asp-controller="BotEmbeddings" asp-action="Details" asp-route-id="@item.EmbeddingId" class="btn btn-sm btn-secondary">檢視</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@{
    long total = ViewBag.TotalCount ?? 0L;
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 25;
    var totalPages = (int)System.Math.Ceiling(total / (double)pageSize);
}

@if (totalPages > 1)
{
    <nav>
        <ul class="pagination pagination-sm">
            <li class="page-item @(page<=1?"disabled":"")">
                <a class="page-link" href="?page=@(page-1)&pageSize=@pageSize&faqId=@ViewBag.FaqId&isActive=@ViewBag.IsActive&provider=@ViewBag.Provider&model=@ViewBag.Model">上一頁</a>
            </li>
            @for (var p = 1; p <= totalPages; p++)
            {
                <li class="page-item @(p==page?"active":"")">
                    <a class="page-link" href="?page=@p&pageSize=@pageSize&faqId=@ViewBag.FaqId&isActive=@ViewBag.IsActive&provider=@ViewBag.Provider&model=@ViewBag.Model">@p</a>
                </li>
            }
            <li class="page-item @(page>=totalPages?"disabled":"")">
                <a class="page-link" href="?page=@(page+1)&pageSize=@pageSize&faqId=@ViewBag.FaqId&isActive=@ViewBag.IsActive&provider=@ViewBag.Provider&model=@ViewBag.Model">下一頁</a>
            </li>
        </ul>
    </nav>
}
