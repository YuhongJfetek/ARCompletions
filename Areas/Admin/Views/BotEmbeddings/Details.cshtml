@model ARCompletions.Domain.BotFaqEmbedding
@{
    ViewData["Title"] = "Embedding Details";
}

<h1>Embedding 詳細</h1>

<dl class="row">
    <dt class="col-sm-2">EmbeddingId</dt>
    <dd class="col-sm-10">@Model.EmbeddingId</dd>

    <dt class="col-sm-2">FaqId</dt>
    <dd class="col-sm-10">@Model.FaqId</dd>

    <dt class="col-sm-2">Provider</dt>
    <dd class="col-sm-10">@Model.EmbeddingProvider</dd>

    <dt class="col-sm-2">Model</dt>
    <dd class="col-sm-10">@Model.EmbeddingModel</dd>

    <dt class="col-sm-2">VectorDim</dt>
    <dd class="col-sm-10">@Model.VectorDim</dd>

    <dt class="col-sm-2">IsActive</dt>
    <dd class="col-sm-10">@(Model.IsActive ? "是" : "否")</dd>

    <dt class="col-sm-2">CreatedAt</dt>
    <dd class="col-sm-10">@Model.CreatedAt</dd>

    <dt class="col-sm-2">RebuiltAt</dt>
    <dd class="col-sm-10">@Model.RebuiltAt</dd>
</dl>

<a asp-area="Admin" asp-controller="BotEmbeddings" asp-action="Index" class="btn btn-secondary">回列表</a>
