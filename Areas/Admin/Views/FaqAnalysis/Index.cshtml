@model IEnumerable<ARCompletions.Domain.ConversationMessage>
@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "FAQ 分析 (低信心 / 未匹配)";
}
@{ #pragma warning disable CS8600 }

<h1>FAQ 分析 — 低信心 / 未匹配</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <label class="form-label">廠商</label>
        <select name="vendorId" class="form-select" asp-items="(SelectList)ViewBag.Vendors">
            <option value="">(全部)</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">篩選</label>
        <select name="filter" class="form-select">
            <option value="" @(ViewBag.ActiveFilter == null ? "selected" : "")>(全部)</option>
            <option value="unmatched" @(ViewBag.ActiveFilter == "unmatched" ? "selected" : "")>未匹配</option>
            <option value="low_confidence" @(ViewBag.ActiveFilter == "low_confidence" ? "selected" : "")>低信心</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">Confidence 閾值</label>
        <input type="number" step="0.01" min="0" max="1" name="confidenceThreshold" class="form-control" value="@(ViewBag.ConfidenceThreshold ?? "")" />
    </div>
    <div class="col-auto align-self-end">
        <button type="submit" class="btn btn-secondary">篩選</button>
    </div>
    <div class="col-auto align-self-end">
        <a asp-action="ExportCsv" asp-route-filter="@ViewBag.ActiveFilter" asp-route-vendorId="@ViewContext.HttpContext.Request.Query["vendorId"]" asp-route-confidenceThreshold="@ViewBag.ConfidenceThreshold" class="btn btn-outline-success">匯出 CSV (最多 5000 筆)</a>
    </div>
</form>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>時間</th>
            <th>Vendor</th>
            <th>Conversation</th>
            <th>方向</th>
            <th>文字</th>
            <th>Route</th>
            <th>Matched FAQ</th>
            <th>Confidence</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var m in Model)
    {
        <tr>
            <td>@(DateTimeOffset.FromUnixTimeSeconds(m.CreatedAt).UtcDateTime)</td>
            <td>@m.VendorId</td>
            <td><a asp-area="Admin" asp-controller="Conversations" asp-action="Details" asp-route-id="@m.ConversationId">@m.ConversationId</a></td>
            <td>@(m.Direction ?? "")</td>
            <td>@(m.MessageText ?? "")</td>
            <td>@(m.SourceType ?? "")</td>
            <td>@(m.SourceFaqId ?? "")</td>
            <td>@(m.ConfidenceScore?.ToString("0.00") ?? "-")</td>
            <td>
                <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary">檢視</a>
            </td>
        </tr>
    }
    </tbody>
</table>

@{
    int curPage = ViewBag.Page is int p ? p : 1;
    int totalPages = ViewBag.TotalPages is int tp ? tp : 1;
    int pageSize = ViewBag.PageSize is int ps ? ps : 50;
    long totalCount = ViewBag.TotalCount is long tc ? tc : 0L;
    string vendorId = ViewContext.HttpContext.Request.Query["vendorId"];
    string filter = ViewContext.HttpContext.Request.Query["filter"];
    string confidence = ViewContext.HttpContext.Request.Query["confidenceThreshold"];
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <div>共 @totalCount 條</div>
    <nav>
        <ul class="pagination mb-0">
            @if (curPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="?vendorId=@vendorId&filter=@filter&confidenceThreshold=@confidence&page=@(curPage-1)&pageSize=@pageSize">上一頁</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">上一頁</span></li>
            }

            @for (int i = 1; i <= totalPages; i++)
            {
                if (i == curPage)
                {
                    <li class="page-item active"><span class="page-link">@i</span></li>
                }
                else if (i <= 3 || i > totalPages - 3 || (i >= curPage - 2 && i <= curPage + 2))
                {
                    <li class="page-item"><a class="page-link" href="?vendorId=@vendorId&filter=@filter&confidenceThreshold=@confidence&page=@i&pageSize=@pageSize">@i</a></li>
                }
                else if (i == 4 && curPage > 6)
                {
                    <li class="page-item disabled"><span class="page-link">…</span></li>
                }
            }

            @if (curPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="?vendorId=@vendorId&filter=@filter&confidenceThreshold=@confidence&page=@(curPage+1)&pageSize=@pageSize">下一頁</a>
                </li>
            }
            else
            {
                <li class="page-item disabled"><span class="page-link">下一頁</span></li>
            }
        </ul>
    </nav>
</div>
@{ #pragma warning restore CS8600 }
