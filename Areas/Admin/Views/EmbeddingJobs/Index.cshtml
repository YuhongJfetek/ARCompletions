@model ARCompletions.Areas.Admin.Models.EmbeddingJobsIndexViewModel
@{
    ViewData["Title"] = "Embedding 任務";
}

<h1>Embedding 任務</h1>

<div class="d-flex justify-content-between mb-2">
    <div>
        <form method="get" class="form-inline">
            <select name="pageSize" class="form-select form-select-sm me-2" onchange="this.form.submit()">
                <option value="10" @(Model.PageSize==10?"selected":"")>10</option>
                <option value="25" @(Model.PageSize==25?"selected":"")>25</option>
                <option value="50" @(Model.PageSize==50?"selected":"")>50</option>
                <option value="100" @(Model.PageSize==100?"selected":"")>100</option>
            </select>
            <input type="hidden" name="vendorId" value="@Model.VendorId" />
            <input type="hidden" name="status" value="@Model.Status" />
            <input type="hidden" name="vectorVersion" value="@Model.VectorVersion" />
        </form>
    </div>
    <div>
        <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("ExportCsv", "EmbeddingJobs", new { area = "Admin", vendorId = Model.VendorId, status = Model.Status, vectorVersion = Model.VectorVersion })">匯出 CSV</a>
    </div>
    <div>
        <form method="post" asp-action="TriggerManual" asp-controller="EmbeddingJobs" asp-area="Admin" class="row g-2" style="display:flex;align-items:center;">
            @Html.AntiForgeryToken()
            <div class="col-auto">
                    <select name="vendorId" class="form-select form-select-sm">
                    @{ var vendors = ViewBag.Vendors as System.Collections.Generic.List<ARCompletions.Domain.Vendor> ?? new System.Collections.Generic.List<ARCompletions.Domain.Vendor>(); }
                    @foreach(var v in vendors)
                    {
                        <option value="@v.Id">@v.Name (@v.Code)</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <input name="vectorVersion" class="form-control form-control-sm" placeholder="向量版本（例如 v1）" />
            </div>
            <div class="col-auto">
                <input name="modelName" class="form-control form-control-sm" placeholder="模型名稱" value="text-embedding-3-small" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">觸發任務</button>
            </div>
        </form>
    </div>
    <div class="text-muted">共 @Model.TotalCount 筆</div>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th style="width:40px;"><input type="checkbox" id="selectAll" /></th>
            <th>JobNo</th>
            <th>Active Vector Version</th>
            <th>Vendor</th>
            <th>狀態</th>
            <th>向量版本</th>
            <th>模型</th>
            <th>FAQ 數</th>
            <th>成功/失敗</th>
            <th>建立時間</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td><input type="checkbox" name="selectedIds" value="@item.Id" class="select-job" /></td>
            <td>@item.JobNo</td>
            @{ var active = ViewBag.ActiveVectorVersion as System.Collections.Generic.Dictionary<string,string> ?? new System.Collections.Generic.Dictionary<string,string>(); }
            <td>@(active.ContainsKey(item.VendorId) ? active[item.VendorId] : "-")</td>
            <td>@item.VendorId</td>
            <td>@item.Status</td>
            <td>@item.VectorVersion</td>
            <td>@item.ModelName</td>
            <td>@item.TotalFaqCount</td>
            <td>@item.SuccessCount / @item.FailCount</td>
            <td>@item.CreatedAt</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">檢視</a>
                <form method="post" asp-action="SetActiveVector" asp-controller="EmbeddingJobs" asp-area="Admin" style="display:inline-block;margin-left:6px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="jobId" value="@item.Id" />
                    <button type="submit" class="btn btn-sm btn-success">設為啟用</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
<div class="mb-3">
    <form id="bulkForm" asp-area="Admin" asp-controller="EmbeddingJobs" asp-action="BulkRetry" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="selectedIds" id="bulkSelectedIds" />
        <input type="hidden" name="vendorId" value="@Model.VendorId" />
        <input type="hidden" name="status" value="@Model.Status" />
        <input type="hidden" name="vectorVersion" value="@Model.VectorVersion" />
        <input type="hidden" name="selectAllMatched" id="selectAllMatched" value="false" />
        <div class="form-check form-check-inline">
            <input class="form-check-input" type="checkbox" id="applyAll" />
            <label class="form-check-label" for="applyAll">套用至所有匹配結果</label>
        </div>
        <button id="bulkRetryBtn" type="submit" class="btn btn-warning btn-sm">重試已選取</button>
    </form>
</div>
<nav>
    <ul class="pagination">
        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
            <a class="page-link" href="?page=@(Model.Page-1)&pageSize=@Model.PageSize&vendorId=@Model.VendorId&status=@Model.Status&vectorVersion=@Model.VectorVersion">上一頁</a>
        </li>
        @for (var p = 1; p <= Model.TotalPages; p++)
        {
            <li class="page-item @(p==Model.Page?"active":"")">
                <a class="page-link" href="?page=@p&pageSize=@Model.PageSize&vendorId=@Model.VendorId&status=@Model.Status&vectorVersion=@Model.VectorVersion">@p</a>
            </li>
        }
        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" href="?page=@(Model.Page+1)&pageSize=@Model.PageSize&vendorId=@Model.VendorId&status=@Model.Status&vectorVersion=@Model.VectorVersion">下一頁</a>
        </li>
    </ul>
</nav>

<script>
    document.getElementById('selectAll')?.addEventListener('change', function (e) {
        var checked = e.target.checked;
        document.querySelectorAll('.select-job').forEach(function(cb){ cb.checked = checked; });
    });

    document.getElementById('bulkForm')?.addEventListener('submit', function (e) {
        var applyAll = document.getElementById('applyAll')?.checked;
        if (applyAll) {
            if (!confirm('確定要重新排隊所有符合目前條件的 job 嗎？這可能會影響大量資料。')) { e.preventDefault(); return false; }
            document.getElementById('selectAllMatched').value = 'true';
            // clear selected ids to avoid confusion
            document.getElementById('bulkSelectedIds').value = '';
            return true;
        }
        var checked = Array.from(document.querySelectorAll('.select-job:checked')).map(function(cb){ return cb.value; });
        if (checked.length === 0) {
            e.preventDefault();
            alert('請先選取至少一個 job。');
            return false;
        }
        if (!confirm('確定要重新排隊所選的 ' + checked.length + ' 個 job 嗎？')) { e.preventDefault(); return false; }
        document.getElementById('bulkSelectedIds').value = checked.join(',');
    });
</script>
