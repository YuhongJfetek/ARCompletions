@model ARCompletions.Domain.EmbeddingJob
@using ARCompletions.Domain
@{
    ViewData["Title"] = "Embedding 任務明細";
    var vendor = ViewBag.Vendor as Vendor;
    var logs = ViewBag.Logs as IEnumerable<EmbeddingLog> ?? Enumerable.Empty<EmbeddingLog>();
}

<h1>Embedding 任務明細</h1>

<h4>基本資訊</h4>
<table class="table table-bordered">
    <tr><th>JobNo</th><td>@Model.JobNo</td></tr>
    <tr><th>Vendor</th><td>@vendor?.Name (@Model.VendorId)</td></tr>
    <tr><th>狀態</th><td>@Model.Status</td></tr>
    <tr><th>向量版本</th><td>@Model.VectorVersion</td></tr>
    <tr><th>模型</th><td>@Model.ModelName</td></tr>
    <tr><th>FAQ 總數</th><td>@Model.TotalFaqCount</td></tr>
    <tr><th>成功/失敗</th><td>@Model.SuccessCount / @Model.FailCount</td></tr>
    <tr><th>開始時間</th><td>@Model.StartedAt</td></tr>
    <tr><th>結束時間</th><td>@Model.FinishedAt</td></tr>
    <tr><th>錯誤訊息</th><td>@Model.ErrorMessage</td></tr>
</table>

<form asp-action="Retry" method="post" class="mb-3">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-warning">重新觸發向量重建</button>
</form>

<h4>執行 Log</h4>
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>時間</th>
            <th>動作</th>
            <th>訊息</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in logs)
    {
        <tr>
            <td>@l.CreatedAt</td>
            <td>@l.ActionType</td>
            <td>@l.Message</td>
        </tr>
    }
    </tbody>
</table>

<p>
    <a asp-action="Index" class="btn btn-secondary">返回列表</a>
</p>
