@model ARCompletions.Areas.Admin.Models.EmbeddingSyncStatusViewModel

@{
    ViewData["Title"] = "同步狀態";
}

<h3>Embedding 同步狀態</h3>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="vendorId" class="form-select">
            <option value="">全部廠商</option>
            @foreach (var v in (ViewBag.Vendors as System.Collections.Generic.List<ARCompletions.Domain.Vendor>))
            {
                <option value="@v.Id" @(Model.VendorId == v.Id ? "selected" : "")>@v.Code</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-primary">查詢</button>
    </div>
</form>

<form method="post" asp-action="RebuildSelected" asp-controller="EmbeddingJobs" asp-area="Admin">
    <input type="hidden" name="vendorId" value="@Model.VendorId" />
    <table class="table table-sm">
        <thead>
            <tr>
                <th style="width:40px"><input type="checkbox" id="chkAll" /></th>
                <th>FaqId</th>
                <th>問題</th>
                <th>FAQ 更新時間</th>
                <th>Embedding 最後建置</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var it in Model.Items)
            {
                var needs = it.LastBuiltAt == null || it.LastBuiltAt < it.FaqUpdatedAt;
                <tr class="@(needs ? "table-warning" : "")">
                    <td><input type="checkbox" name="selectedFaqIds" value="@it.FaqId" /></td>
                    <td>@it.FaqId</td>
                    <td>@it.Question</td>
                    <td>@(System.DateTimeOffset.FromUnixTimeSeconds(it.FaqUpdatedAt).ToLocalTime())</td>
                    <td>@(it.LastBuiltAt.HasValue ? System.DateTimeOffset.FromUnixTimeSeconds(it.LastBuiltAt.Value).ToLocalTime().ToString() : "- 未建置 -")</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mb-3">
        <button type="submit" class="btn btn-sm btn-primary">重新建置選取項目</button>
        @if (!string.IsNullOrEmpty(Model.VendorId))
        {
            <a class="btn btn-sm btn-outline-secondary" href="@Url.Action("TriggerManual", "EmbeddingJobs", new { area = "Admin", vendorId = Model.VendorId })">一鍵重建整個廠商</a>
        }
    </div>
</form>

<script>
document.getElementById('chkAll')?.addEventListener('change', function(e){
    var checked = e.target.checked;
    document.querySelectorAll('input[name="selectedFaqIds"]').forEach(function(cb){ cb.checked = checked; });
});
</script>
