@model ARCompletions.Domain.MessageResult
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>訊息結果詳情</h2>

<dl class="row">
    <dt class="col-sm-2">編號</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">建立時間</dt>
    <dd class="col-sm-10">@DateTimeOffset.FromUnixTimeSeconds(Model.CreatedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</dd>

    <dt class="col-sm-2">對話編號</dt>
    <dd class="col-sm-10">@Model.ConversationId</dd>

    <dt class="col-sm-2">訊息編號</dt>
    <dd class="col-sm-10">@Model.MessageId</dd>

    <dt class="col-sm-2">廠商</dt>
    <dd class="col-sm-10">@Model.VendorId</dd>

    <dt class="col-sm-2">路由</dt>
    <dd class="col-sm-10">@(Model.Route ?? "-")</dd>

    <dt class="col-sm-2">訊息路由編號</dt>
    <dd class="col-sm-10">@if(!string.IsNullOrWhiteSpace(Model.MessageRouteId)) { <a asp-area="Admin" asp-controller="MessageRoutes" asp-action="Details" asp-route-id="@Model.MessageRouteId">@Model.MessageRouteId</a> } else { <span>-</span> }</dd>

    <dt class="col-sm-2">已匹配 FAQ</dt>
    <dd class="col-sm-10">@Model.MatchedFaqId</dd>

    <dt class="col-sm-2">信心</dt>
    <dd class="col-sm-10">@(Model.Confidence?.ToString("F3") ?? "-")</dd>

    <dt class="col-sm-2">匹配方式</dt>
    <dd class="col-sm-10">@(Model.MatchedBy ?? "-")</dd>

    <dt class="col-sm-2">匹配分數</dt>
    <dd class="col-sm-10">@(Model.MatchedScore?.ToString("F3") ?? "-")</dd>

    <dt class="col-sm-2">建立者</dt>
    <dd class="col-sm-10">@Model.CreatedBy</dd>

    <dt class="col-sm-2">原始內容</dt>
    <dd class="col-sm-10">
        <div class="mb-2"><button id="copyPayload" class="btn btn-sm btn-outline-secondary">複製</button></div>
        <pre id="payloadPre" style="max-height:480px;overflow:auto;white-space:pre-wrap;">@Model.Payload</pre>
    </dd>
</dl>

@section Scripts {
    <script>
        document.getElementById('copyPayload')?.addEventListener('click', function(){
            var txt = document.getElementById('payloadPre')?.innerText || '';
            if (navigator.clipboard) navigator.clipboard.writeText(txt).then(function(){ alert('Copied'); });
        });
    </script>
}
