@model IEnumerable<ARCompletions.Domain.MessageResult>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var page = (int)(ViewBag.Page ?? 1);
    var pageSize = (int)(ViewBag.PageSize ?? 25);
    var total = (int)(ViewBag.Total ?? 0);
}

<h2>訊息結果</h2>

<form id="filterForm" class="row g-2 mb-3" method="get">
    <div class="col-auto">
        <input type="date" name="dateFrom" class="form-control" value="@(ViewBag.FilterDateFrom != null ? DateTimeOffset.FromUnixTimeSeconds((long)ViewBag.FilterDateFrom).ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="col-auto">
        <input type="date" name="dateTo" class="form-control" value="@(ViewBag.FilterDateTo != null ? DateTimeOffset.FromUnixTimeSeconds((long)ViewBag.FilterDateTo).ToString("yyyy-MM-dd") : "")" />
    </div>
    <div class="col-auto">
        <select name="matched" class="form-select">
            <option value="">All</option>
            <option value="matched" @(ViewBag.FilterMatched=="matched"?"selected":"")>Matched</option>
            <option value="unmatched" @(ViewBag.FilterMatched=="unmatched"?"selected":"")>Unmatched</option>
        </select>
    </div>
    <div class="col-auto">
        <input name="vendorId" class="form-control" placeholder="VendorId (optional)" value="@(ViewBag.FilterVendor ?? "")" />
    </div>
    <div class="col-auto">
        <button class="btn btn-primary" type="submit">Filter</button>
        <a class="btn btn-sm btn-outline-secondary ms-2 export-csv-btn" data-base-url="@Url.Action("ExportCsv")">Export CSV</a>
    </div>
</form>

<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>時間</th>
            <th>廠商</th>
            <th>訊息編號</th>
            <th>來源</th>
            <th>路由</th>
            <th>已匹配 FAQ</th>
            <th>信心</th>
            <th>匹配方式</th>
            <th>建立者</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var m in Model)
    {
        var when = DateTimeOffset.FromUnixTimeSeconds(m.CreatedAt).ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss");
        <tr>
            <td>@when</td>
            <td>@m.VendorId</td>
            <td><a asp-action="Details" asp-route-id="@m.Id">@m.MessageId</a></td>
            <td>@m.Source</td>
            <td>@(m.Route ?? "-")</td>
            <td>@m.MatchedFaqId</td>
            <td>@(m.Confidence?.ToString("F3") ?? "-")</td>
            <td>@(m.MatchedBy ?? "-")</td>
            <td>@m.CreatedBy</td>
        </tr>
    }
    </tbody>
</table>

<nav>
  <ul class="pagination">
    @for (int i = 1; i <= (int)Math.Ceiling((double)total / pageSize); i++)
    {
        <li class="page-item @(i==page?"active":"")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@pageSize">@i</a></li>
    }
  </ul>
</nav>

<script>
document.addEventListener('DOMContentLoaded', function(){
    var form = document.getElementById('filterForm');
    if (!form) return;
    function dateToUnix(dateStr){
        if (!dateStr) return '';
        var d = new Date(dateStr + 'T00:00:00');
        return Math.floor(d.getTime()/1000);
    }
    form.addEventListener('submit', function(e){
        var df = form.querySelector('input[name="dateFrom"]');
        var dt = form.querySelector('input[name="dateTo"]');
        if (df && df.value) df.value = dateToUnix(df.value);
        if (dt && dt.value) dt.value = dateToUnix(dt.value) + 86399; // include end of day
    });
    var exportBtn = form.querySelector('.export-csv-btn');
    if (exportBtn){
        exportBtn.addEventListener('click', function(ev){
            ev.preventDefault();
            var params = new URLSearchParams();
            var df = form.querySelector('input[name="dateFrom"]');
            var dt = form.querySelector('input[name="dateTo"]');
            var vendor = form.querySelector('input[name="vendorId"]');
            var matched = form.querySelector('select[name="matched"]');
            if (df && df.value) params.set('dateFrom', dateToUnix(df.value));
            if (dt && dt.value) params.set('dateTo', dateToUnix(dt.value) + 86399);
            if (vendor && vendor.value) params.set('vendorId', vendor.value);
            if (matched && matched.value) params.set('matched', matched.value);
            var base = exportBtn.dataset.baseUrl || window.location.pathname;
            var url = base + (params.toString() ? ('?' + params.toString()) : '');
            window.location.href = url;
        });
    }
});
</script>
