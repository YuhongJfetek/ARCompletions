@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Embedding 設定";
}

<h3>Embedding 設定</h3>

<table class="table table-sm">
    <thead>
        <tr>
            <th>廠商</th>
            <th>Active Vector Version</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in Model)
        {
            var vendorId = (string)row.Id;
            var code = (string)row.Code;
            var setting = row.Setting as ARCompletions.Domain.EmbeddingSetting;
            <tr>
                <td>@code</td>
                <td>
                    <form method="post" asp-action="Update" asp-controller="EmbeddingSettings" asp-area="Admin" style="display:flex;gap:8px;align-items:center;">
                        <input type="hidden" name="vendorId" value="@vendorId" />
                        <input name="activeVectorVersion" class="form-control form-control-sm" value="@(setting?.ActiveVectorVersion ?? "")" />
                        <button class="btn btn-sm btn-primary">更新</button>
                    </form>
                </td>
                <td></td>
            </tr>
        }
    </tbody>
</table>
