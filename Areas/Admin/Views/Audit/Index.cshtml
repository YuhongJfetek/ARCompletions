@model IEnumerable<ARCompletions.Domain.AuditLog>
@{
    ViewData["Title"] = "稽核日誌";
    int page = ViewBag.Page ?? 1; int pageSize = ViewBag.PageSize ?? 50; long total = ViewBag.TotalCount ?? 0L;
}

<h1>稽核日誌</h1>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <label class="form-label">動作</label>
        <input name="action" class="form-control" value="@(ViewBag.ActiveAction ?? "")" />
    </div>
    <div class="col-auto">
        <label class="form-label">開始日期</label>
        <input type="date" name="dateFrom" class="form-control" value="@(ViewBag.DateFrom ?? "")" />
    </div>
    <div class="col-auto">
        <label class="form-label">結束日期</label>
        <input type="date" name="dateTo" class="form-control" value="@(ViewBag.DateTo ?? "")" />
    </div>
    <div class="col-auto align-self-end">
        <button class="btn btn-secondary">篩選</button>
    </div>
</form>

<table class="table table-sm table-striped">
    <thead><tr><th>時間</th><th>操作者</th><th>動作</th><th>目標</th><th>內容</th><th></th></tr></thead>
    <tbody>
    @foreach(var a in Model)
    {
        <tr>
            <td>@(DateTimeOffset.FromUnixTimeSeconds(a.Timestamp).UtcDateTime)</td>
            <td>@a.Actor</td>
            <td>@a.Action</td>
            <td>@a.TargetId</td>
            <td><pre style="max-height:80px;overflow:auto">@a.Payload</pre></td>
            <td><a asp-action="Details" asp-route-id="@a.Id" class="btn btn-sm btn-secondary">檢視</a></td>
        </tr>
    }
    </tbody>
</table>

<div>共 @total 筆</div>
