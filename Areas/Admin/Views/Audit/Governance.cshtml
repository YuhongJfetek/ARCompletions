@model IEnumerable<ARCompletions.Domain.SystemSetting>
@{
    ViewData["Title"] = "治理設定";
}

<h1>治理設定</h1>

<table class="table table-sm">
    <thead><tr><th>鍵</th><th>值</th><th>更新時間</th><th></th></tr></thead>
    <tbody>
    @foreach(var s in Model)
    {
        <tr>
            <td>@s.SettingKey</td>
            <td>@s.SettingValue</td>
            <td>@(DateTimeOffset.FromUnixTimeSeconds(s.UpdatedAt).UtcDateTime)</td>
            <td>
                <form method="post" asp-action="UpdateSetting" asp-controller="Audit" asp-area="Admin">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@s.Id" />
                    <input type="text" name="value" value="@s.SettingValue" class="form-control form-control-sm d-inline-block" style="width:420px;" />
                    <button class="btn btn-sm btn-primary ms-2">儲存</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
