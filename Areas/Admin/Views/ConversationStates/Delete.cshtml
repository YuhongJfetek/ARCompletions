@model ARCompletions.Domain.ConversationState

<h2>刪除 對話狀態</h2>

<p>Are you sure you want to delete this conversation state?</p>

<dl class="row">
    <dt class="col-sm-3">對話編號</dt>
    <dd class="col-sm-9">@Model.ConversationId</dd>
    <dt class="col-sm-3">廠商 Id</dt>
    <dd class="col-sm-9">@Model.VendorId</dd>
</dl>

<form asp-area="Admin" asp-controller="ConversationStates" asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-area="Admin" asp-controller="ConversationStates" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
