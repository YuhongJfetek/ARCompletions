@model ARCompletions.Domain.ConversationState

<h2>Edit Conversation State</h2>

<form asp-area="Admin" asp-controller="ConversationStates" asp-action="Edit" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="form-group">
        <label>VendorId</label>
        <input class="form-control" name="VendorId" value="@Model.VendorId" />
    </div>
    <div class="form-group">
        <label>SourceType</label>
        <input class="form-control" name="SourceType" value="@Model.SourceType" />
    </div>
    <div class="form-group">
        <label>ConversationId</label>
        <input class="form-control" name="ConversationId" value="@Model.ConversationId" />
    </div>
    <div class="form-group">
        <label>BotEnabled</label>
        <input type="checkbox" name="BotEnabled" @(Model.BotEnabled ? "checked" : "") />
    </div>
    <div class="form-group">
        <label>HandoffUntil (unix seconds)</label>
        <input class="form-control" name="HandoffUntil" value="@Model.HandoffUntil" />
    </div>
    <button type="submit" class="btn btn-primary">Save</button>
</form>
