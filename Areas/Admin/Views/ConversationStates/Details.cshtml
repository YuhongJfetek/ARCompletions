@model ARCompletions.Domain.ConversationState

<h2>對話狀態詳情</h2>

<dl class="row">
    <dt class="col-sm-3">廠商 Id</dt>
    <dd class="col-sm-9">@Model.VendorId</dd>

    <dt class="col-sm-3">來源類型</dt>
    <dd class="col-sm-9">@Model.SourceType</dd>

    <dt class="col-sm-3">對話編號</dt>
    <dd class="col-sm-9">@Model.ConversationId</dd>

    <dt class="col-sm-3">機器人啟用</dt>
    <dd class="col-sm-9">@Model.BotEnabled</dd>

    <dt class="col-sm-3">交接至</dt>
    <dd class="col-sm-9">@Model.HandoffUntil</dd>

    <dt class="col-sm-3">更新時間</dt>
    <dd class="col-sm-9">@Model.UpdatedAt</dd>
</dl>

<p>
    <a asp-area="Admin" asp-controller="ConversationStates" asp-action="Edit" asp-route-id="@Model.Id">Edit</a> |
    <a asp-area="Admin" asp-controller="ConversationStates" asp-action="Index">Back to list</a>
</p>
