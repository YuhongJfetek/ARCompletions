@model ARCompletions.Domain.ConversationState

<h2>新增 對話狀態</h2>

<form asp-area="Admin" asp-controller="ConversationStates" asp-action="Create" method="post">
    <div class="form-group">
        <label>VendorId</label>
        <input class="form-control" name="VendorId" />
    </div>
    <div class="form-group">
        <label>SourceType</label>
        <input class="form-control" name="SourceType" />
    </div>
    <div class="form-group">
        <label>ConversationId</label>
        <input class="form-control" name="ConversationId" />
    </div>
    <div class="form-group">
        <label>BotEnabled</label>
        <input type="checkbox" name="BotEnabled" />
    </div>
    <div class="form-group">
        <label>HandoffUntil (unix seconds)</label>
        <input class="form-control" name="HandoffUntil" />
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>
