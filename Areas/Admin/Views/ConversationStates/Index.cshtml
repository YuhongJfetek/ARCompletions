@model IEnumerable<ARCompletions.Domain.ConversationState>

<h2>對話狀態</h2>

<p><a asp-area="Admin" asp-controller="ConversationStates" asp-action="Create">新增</a></p>

<table class="table">
    <thead>
        <tr>
            <th>VendorId</th>
            <th>SourceType</th>
            <th>ConversationId</th>
            <th>BotEnabled</th>
            <th>HandoffUntil</th>
            <th>UpdatedAt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model) {
        <tr>
            <td>@item.VendorId</td>
            <td>@item.SourceType</td>
            <td>@item.ConversationId</td>
            <td>@item.BotEnabled</td>
            <td>@item.HandoffUntil</td>
            <td>@item.UpdatedAt</td>
            <td>
                <a asp-area="Admin" asp-controller="ConversationStates" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-area="Admin" asp-controller="ConversationStates" asp-action="Edit" asp-route-id="@item.Id">編輯</a> |
                <a asp-area="Admin" asp-controller="ConversationStates" asp-action="Delete" asp-route-id="@item.Id">刪除</a>
            </td>
        </tr>
    }
    </tbody>
</table>
