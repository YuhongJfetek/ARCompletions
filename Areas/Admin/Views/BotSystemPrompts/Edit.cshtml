@model ARCompletions.Domain.BotSystemPrompt
@{
    ViewData["Title"] = "Edit System Prompt";
}

<h1>編輯 System Prompt</h1>

<form asp-area="Admin" asp-controller="BotSystemPrompts" asp-action="Edit" method="post">
    <input type="hidden" asp-for="PromptKey" />
    <div class="mb-2">
        <label class="form-label">PromptKey</label>
        <input class="form-control" value="@Model.PromptKey" disabled />
    </div>
    <div class="mb-2">
        <label asp-for="PromptText" class="form-label"></label>
        <textarea asp-for="PromptText" class="form-control" rows="10"></textarea>
        <span asp-validation-for="PromptText" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">儲存</button>
    <a asp-area="Admin" asp-controller="BotSystemPrompts" asp-action="Index" class="btn btn-secondary ms-2">取消</a>
</form>
