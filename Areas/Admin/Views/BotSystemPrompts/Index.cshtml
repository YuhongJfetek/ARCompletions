@model IEnumerable<ARCompletions.Domain.BotSystemPrompt>
@{
    ViewData["Title"] = "Bot System Prompts";
}

<h1>Bot System Prompts</h1>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>PromptKey</th>
            <th>UpdatedAt</th>
            <th>UpdatedBy</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.PromptKey</td>
            <td>@item.UpdatedAt</td>
            <td>@item.UpdatedBy</td>
            <td>
                <a asp-area="Admin" asp-controller="BotSystemPrompts" asp-action="Edit" asp-route-id="@item.PromptKey" class="btn btn-sm btn-secondary">編輯</a>
            </td>
        </tr>
    }
    </tbody>
</table>
