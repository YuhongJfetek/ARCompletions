@model dynamic
@{
    ViewData["Title"] = "群組詳細";
}

<h2>群組詳細（範本）</h2>

<dl class="row">
    <dt class="col-sm-2">編號</dt>
    <dd class="col-sm-10">@Model.Id</dd>

    <dt class="col-sm-2">名稱</dt>
    <dd class="col-sm-10">@Model.Name</dd>
    
    <dt class="col-sm-2">備註</dt>
    <dd class="col-sm-10">(未實作)</dd>
</dl>

<a asp-area="Admin" asp-controller="Groups" asp-action="Index" class="btn btn-secondary">Back</a>
