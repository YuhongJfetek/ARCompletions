@{
    ViewData["Title"] = "新增群組";
}

<h2>新增群組（範本）</h2>

<form asp-area="Admin" asp-controller="Groups" asp-action="Create" method="post">
    <div class="mb-3">
        <label class="form-label">名稱</label>
        <input class="form-control" name="name" />
    </div>
    <div class="mb-3 form-check">
        <input class="form-check-input" type="checkbox" name="botEnabled" />
        <label class="form-check-label">啟用 Bot</label>
    </div>
    <button class="btn btn-primary" type="submit">建立</button>
    <a asp-area="Admin" asp-controller="Groups" asp-action="Index" class="btn btn-secondary">取消</a>
</form>

<p class="text-muted">注意：此為 scaffold 範本，尚未連接資料庫。</p>
