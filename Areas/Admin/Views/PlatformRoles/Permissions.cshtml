@model ARCompletions.Areas.Admin.Models.PlatformRolePermissionsViewModel
@{
    ViewData["Title"] = "角色權限設定";
}

<h1>角色權限設定 - @Model.RoleName</h1>

<form asp-action="Permissions" method="post">
    <input type="hidden" asp-for="RoleId" />
    <div class="mb-3">
        <label class="form-label">權限</label>
        <select asp-for="SelectedPermissionIds" asp-items="(SelectList)ViewBag.AllPermissions" class="form-select" multiple size="10"></select>
    </div>
    <button type="submit" class="btn btn-primary">儲存</button>
    <a asp-action="Index" class="btn btn-secondary">返回列表</a>
</form>
