@model ARCompletions.Domain.FaqCandidate
@{
    ViewData["Title"] = "Candidate Details";
}

<h1>Candidate</h1>
<table class="table table-bordered">
    <tr><th>Question</th><td>@Model.Question</td></tr>
    <tr><th>Answer</th><td>@Model.Answer</td></tr>
    <tr><th>Vendor</th><td>@Model.VendorId</td></tr>
    <tr><th>Confidence</th><td>@(Model.ConfidenceScore?.ToString("0.00") ?? "-")</td></tr>
    <tr><th>Suggested Category</th><td>@Model.SuggestedCategory</td></tr>
    <tr><th>Source Conversations</th><td>@Model.SourceConversationIds</td></tr>
    <tr><th>AI Suggestion</th><td><pre>@Model.AiSuggestionJson</pre></td></tr>
    <tr><th>Status</th><td>@Model.Status</td></tr>
    <tr><th>CreatedAt</th><td>@(DateTimeOffset.FromUnixTimeSeconds(Model.CreatedAt).UtcDateTime)</td></tr>
    <tr><th>ReviewedAt</th><td>@(Model.ReviewedAt != null ? DateTimeOffset.FromUnixTimeSeconds(Model.ReviewedAt.Value).UtcDateTime.ToString() : "-")</td></tr>
    <tr><th>ReviewedBy</th><td>@Model.ReviewedByType / @Model.ReviewedById</td></tr>
</table>

<form method="post" asp-action="MarkReviewed" asp-controller="KnowledgeCandidates" asp-area="Admin">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <input type="hidden" name="reviewerId" value="" />
    <button class="btn btn-primary">Mark Reviewed</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
</form>
