@model IEnumerable<ARCompletions.Domain.FaqCandidate>
@{
    ViewData["Title"] = "Knowledge Candidates";
    int page = ViewBag.Page ?? 1; int pageSize = ViewBag.PageSize ?? 25; long total = ViewBag.TotalCount ?? 0L;
}

<h1>知識候選</h1>

<table class="table table-striped">
    <thead><tr><th>Question</th><th>Vendor</th><th>Confidence</th><th>Status</th><th>CreatedAt</th><th></th></tr></thead>
    <tbody>
    @foreach(var c in Model)
    {
        <tr>
            <td>@c.Question</td>
            <td>@c.VendorId</td>
            <td>@(c.ConfidenceScore?.ToString("0.00") ?? "-")</td>
            <td>@c.Status</td>
            <td>@(DateTimeOffset.FromUnixTimeSeconds(c.CreatedAt).UtcDateTime)</td>
            <td><a asp-action="Details" asp-route-id="@c.Id" class="btn btn-sm btn-secondary">檢視</a></td>
        </tr>
    }
    </tbody>
</table>

<div>共 @total 筆</div>
