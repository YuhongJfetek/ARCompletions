@model IEnumerable<ARCompletions.Domain.BotStaffUser>
@{
    ViewData["Title"] = "Bot Staff Users";
}

<h1>Bot Staff 使用者</h1>

<form method="get" class="row g-2 mb-2">
    <div class="col-auto">
        <input name="q" value="@ViewBag.Query" placeholder="UserId / Name" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <input name="role" value="@ViewBag.Role" placeholder="Role" class="form-control form-control-sm" />
    </div>
    <div class="col-auto">
        <select name="enabled" class="form-select form-select-sm">
            <option value="">全部</option>
            <option value="true" selected="@(ViewBag.Enabled == true ? "selected" : null)">啟用</option>
            <option value="false" selected="@(ViewBag.Enabled == false ? "selected" : null)">停用</option>
        </select>
    </div>
    <div class="col-auto">
        <button class="btn btn-sm btn-primary" type="submit">搜尋</button>
        <a asp-area="Admin" asp-controller="BotStaffUsers" asp-action="Create" class="btn btn-sm btn-success ms-2">新增 Staff</a>
    </div>
</form>

<table class="table table-striped table-sm">
    <thead>
        <tr>
            <th>UserId</th>
            <th>Name</th>
            <th>Role</th>
            <th>Enabled</th>
            <th>CreatedAt</th>
            <th>UpdatedAt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.UserId</td>
            <td>@item.Name</td>
            <td>@item.Role</td>
            <td>@(item.Enabled ? "是" : "否")</td>
            <td>@item.CreatedAt</td>
            <td>@item.UpdatedAt</td>
            <td>
                <a asp-area="Admin" asp-controller="BotStaffUsers" asp-action="Edit" asp-route-id="@item.UserId" class="btn btn-sm btn-secondary">編輯</a>
                <a asp-area="Admin" asp-controller="BotStaffUsers" asp-action="Details" asp-route-id="@item.UserId" class="btn btn-sm btn-outline-secondary">檢視</a>
            </td>
        </tr>
    }
    </tbody>
</table>
