@model ARCompletions.Domain.BotStaffUser
@{
    ViewData["Title"] = "Staff User Details";
}

<h1>Staff 使用者詳細</h1>

<dl class="row">
    <dt class="col-sm-2">UserId</dt>
    <dd class="col-sm-10">@Model.UserId</dd>

    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Role</dt>
    <dd class="col-sm-10">@Model.Role</dd>

    <dt class="col-sm-2">Enabled</dt>
    <dd class="col-sm-10">@(Model.Enabled ? "是" : "否")</dd>

    <dt class="col-sm-2">CreatedAt</dt>
    <dd class="col-sm-10">@Model.CreatedAt</dd>

    <dt class="col-sm-2">UpdatedAt</dt>
    <dd class="col-sm-10">@Model.UpdatedAt</dd>
</dl>

<a asp-area="Admin" asp-controller="BotStaffUsers" asp-action="Index" class="btn btn-secondary">回列表</a>
