@model IEnumerable<ARCompletions.Domain.Vendor>
@{
    ViewData["Title"] = "廠商列表";
}

<h1>廠商列表</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">新增廠商</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>代碼</th>
            <th>名稱</th>
            <th>聯絡人</th>
            <th>啟用</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Code</td>
            <td>@item.Name</td>
            <td>@item.ContactName</td>
            <td>@(item.IsActive ? "是" : "否")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">編輯</a>
            </td>
        </tr>
    }
    </tbody>
</table>
