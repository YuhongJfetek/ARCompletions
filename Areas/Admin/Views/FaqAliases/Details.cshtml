@model ARCompletions.Domain.FaqAlias

<h2>FAQ 別名詳情</h2>

<dl class="row">
    <dt class="col-sm-3">詞</dt>
    <dd class="col-sm-9">@Model.Term</dd>

    <dt class="col-sm-3">同義詞</dt>
    <dd class="col-sm-9">@Model.Synonyms</dd>

    <dt class="col-sm-3">FAQ Ids</dt>
    <dd class="col-sm-9">@Model.FaqIds</dd>

    <dt class="col-sm-3">模式</dt>
    <dd class="col-sm-9">@Model.Mode</dd>

    <dt class="col-sm-3">啟用</dt>
    <dd class="col-sm-9">@Model.IsActive</dd>
</dl>

<p>
    <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Edit" asp-route-id="@Model.Id">編輯</a> |
    <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Index">回到列表</a>
</p>
