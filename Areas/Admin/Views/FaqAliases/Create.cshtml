@model ARCompletions.Domain.FaqAlias

<h2>Create FAQ Alias</h2>

<form asp-area="Admin" asp-controller="FaqAliases" asp-action="Create" method="post">
    <div class="form-group">
        <label>VendorId</label>
        <input class="form-control" name="VendorId" />
    </div>
    <div class="form-group">
        <label>Term</label>
        <input class="form-control" name="Term" />
    </div>
    <div class="form-group">
        <label>Synonyms (JSON array)</label>
        <textarea class="form-control" name="Synonyms"></textarea>
    </div>
    <div class="form-group">
        <label>Mode</label>
        <input class="form-control" name="Mode" value="direct" />
    </div>
    <div class="form-group">
        <label>FaqIds (JSON array)</label>
        <input class="form-control" name="FaqIds" />
    </div>
    <div class="form-group">
        <label>IsActive</label>
        <input type="checkbox" name="IsActive" checked />
    </div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>
