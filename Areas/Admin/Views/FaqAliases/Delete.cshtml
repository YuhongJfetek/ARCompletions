@model ARCompletions.Domain.FaqAlias

<h2>停用 FAQ 別名</h2>

<p>確定要停用此 FAQ 別名嗎？停用後不會從資料庫移除。</p>

<dl class="row">
    <dt class="col-sm-3">詞</dt>
    <dd class="col-sm-9">@Model.Term</dd>
    <dt class="col-sm-3">FAQ Ids</dt>
    <dd class="col-sm-9">@Model.FaqIds</dd>
</dl>

<form asp-area="Admin" asp-controller="FaqAliases" asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">停用</button>
    <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Index" class="btn btn-secondary">取消</a>
</form>
