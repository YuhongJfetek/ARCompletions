@model ARCompletions.Domain.FaqAlias

<h2>刪除 FAQ 別名</h2>

<p>Are you sure you want to delete this FAQ alias?</p>

<dl class="row">
    <dt class="col-sm-3">詞</dt>
    <dd class="col-sm-9">@Model.Term</dd>
    <dt class="col-sm-3">FAQ Ids</dt>
    <dd class="col-sm-9">@Model.FaqIds</dd>
</dl>

<form asp-area="Admin" asp-controller="FaqAliases" asp-action="DeleteConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">刪除</button>
    <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
