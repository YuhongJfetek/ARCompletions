@model ARCompletions.Domain.FaqAlias

<h2>編輯 FAQ 別名</h2>

<form asp-area="Admin" asp-controller="FaqAliases" asp-action="Edit" method="post">
    <input type="hidden" name="Id" value="@Model.Id" />
    <div class="form-group">
        <label>Term</label>
        <input class="form-control" name="Term" value="@Model.Term" />
    </div>
    <div class="form-group">
        <label>Synonyms (JSON array)</label>
        <textarea class="form-control" name="Synonyms">@Model.Synonyms</textarea>
    </div>
    <div class="form-group">
        <label>Mode</label>
        <input class="form-control" name="Mode" value="@Model.Mode" />
    </div>
    <div class="form-group">
        <label>FaqIds (JSON array)</label>
        <input class="form-control" name="FaqIds" value="@Model.FaqIds" />
    </div>
    <div class="form-group">
        <label>IsActive</label>
        <input type="checkbox" name="IsActive" @(Model.IsActive ? "checked" : "") />
    </div>
    <button type="submit" class="btn btn-primary">儲存</button>
</form>
