@model IEnumerable<ARCompletions.Domain.FaqAlias>

<h2>FAQ 別名</h2>

<p><a asp-area="Admin" asp-controller="FaqAliases" asp-action="Create">新增</a></p>

<table class="table">
    <thead>
        <tr>
            <th>詞</th>
            <th>模式</th>
            <th>FAQ Ids</th>
            <th>啟用</th>
            <th>建立時間</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model) {
        <tr>
            <td>@item.Term</td>
            <td>@item.Mode</td>
            <td>@item.FaqIds</td>
            <td>@(item.IsActive ? "是" : "否")</td>
            <td>@item.CreatedAt</td>
            <td>
                <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Details" asp-route-id="@item.Id">檢視</a> |
                <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Edit" asp-route-id="@item.Id">編輯</a> |
                <form asp-area="Admin" asp-controller="FaqAliases" asp-action="ToggleActive" method="post" style="display:inline">
                    <input type="hidden" name="id" value="@item.Id" />
                    <button type="submit" class="btn btn-link p-0">@(item.IsActive ? "停用" : "啟用")</button>
                </form>
                |
                <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Delete" asp-route-id="@item.Id">停用（舊）</a>
            </td>
        </tr>
    }
    </tbody>
</table>
