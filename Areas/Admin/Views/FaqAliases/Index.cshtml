@model IEnumerable<ARCompletions.Domain.FaqAlias>

<h2>FAQ Aliases</h2>

<p><a asp-area="Admin" asp-controller="FaqAliases" asp-action="Create">Create New</a></p>

<table class="table">
    <thead>
        <tr>
            <th>Term</th>
            <th>Mode</th>
            <th>FaqIds</th>
            <th>IsActive</th>
            <th>CreatedAt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var item in Model) {
        <tr>
            <td>@item.Term</td>
            <td>@item.Mode</td>
            <td>@item.FaqIds</td>
            <td>@item.IsActive</td>
            <td>@item.CreatedAt</td>
            <td>
                <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-area="Admin" asp-controller="FaqAliases" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
