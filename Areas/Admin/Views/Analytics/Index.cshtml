@{
    ViewData["Title"] = "Analytics";
    var conf = ViewBag.ConfidenceStats;
    var persona = ViewBag.PersonaSettings as System.Collections.Generic.List<ARCompletions.Domain.SystemSetting> ?? new System.Collections.Generic.List<ARCompletions.Domain.SystemSetting>();
}

<h1>Analytics Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h5>Total Conversations</h5>
            <div class="display-6">@ViewBag.TotalConversations</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h5>Total Messages</h5>
            <div class="display-6">@ViewBag.TotalMessages</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 mb-3">
            <h5>Low Confidence (&lt; 0.5)</h5>
            <div class="display-6">@ViewBag.LowConfidenceCount</div>
        </div>
    </div>
</div>

<div class="row mb-3">
    <div class="col-md-6">
        <h5>Confidence Stats</h5>
        <ul>
            <li>Average: @(conf?.Avg != null ? ((double)conf.Avg).ToString("0.00") : "-")</li>
            <li>Min: @(conf?.Min != null ? ((double)conf.Min).ToString("0.00") : "-")</li>
            <li>Max: @(conf?.Max != null ? ((double)conf.Max).ToString("0.00") : "-")</li>
        </ul>
    </div>
    <div class="col-md-6">
        <h5>Embedding Jobs (recent)</h5>
        <ul>
        @{ var recent = ViewBag.RecentEmbedJobs as System.Collections.Generic.List<ARCompletions.Domain.EmbeddingJob> ?? new System.Collections.Generic.List<ARCompletions.Domain.EmbeddingJob>(); }
        @foreach(var j in recent)
        {
            <li>@j.JobNo — @j.VendorId — @j.VectorVersion — @j.Status</li>
        }
        </ul>
    </div>
</div>

<h3>Persona Settings</h3>
<p>Manage personas used by the response generator. Keys are arbitrary labels.</p>
    <table class="table table-sm">
    <thead><tr><th>Key</th><th>Value</th><th>UpdatedAt</th><th>Actions</th></tr></thead>
    <tbody>
    @foreach(var s in persona)
    {
        var sk = s.SettingKey.Substring("Persona:".Length);
        <tr>
            <td>@sk</td>
            <td>@s.SettingValue</td>
            <td>@(DateTimeOffset.FromUnixTimeSeconds(s.UpdatedAt).UtcDateTime)</td>
            <td>
                <a asp-action="Edit" asp-route-key="@sk" class="btn btn-sm btn-outline-primary">Edit</a>
                <form method="post" asp-action="DeletePersona" asp-controller="Analytics" asp-area="Admin" style="display:inline-block;margin-left:6px;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="key" value="@sk" />
                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete persona "' + '@sk' + '"?');">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<h5>Add / Update Persona</h5>
<form method="post" asp-action="SavePersona" asp-controller="Analytics" asp-area="Admin">
    @Html.AntiForgeryToken()
    <div class="row g-2">
        <div class="col-md-3"><input name="key" class="form-control" placeholder="persona_key" /></div>
        <div class="col-md-6"><input name="value" class="form-control" placeholder="persona JSON or text" /></div>
        <div class="col-md-3"><button class="btn btn-primary">Save</button></div>
    </div>
</form>
