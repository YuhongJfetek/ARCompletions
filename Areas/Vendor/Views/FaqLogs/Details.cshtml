@model ARCompletions.Domain.FaqLog
@{
    ViewData["Title"] = "FAQ 操作紀錄詳情";
}

<h1>FAQ 操作紀錄詳情</h1>

<dl class="row">
    <dt class="col-sm-3">時間</dt>
    <dd class="col-sm-9">@(System.DateTimeOffset.FromUnixTimeSeconds(Model.OperatedAt).UtcDateTime.ToString("yyyy-MM-dd HH:mm:ss"))</dd>

    <dt class="col-sm-3">操作</dt>
    <dd class="col-sm-9">@Model.ActionType</dd>

    <dt class="col-sm-3">FAQ</dt>
    <dd class="col-sm-9">@Model.FaqId</dd>

    <dt class="col-sm-3">操作人</dt>
    <dd class="col-sm-9">@Model.OperatedByType / @Model.OperatedById</dd>

    <dt class="col-sm-3">After JSON</dt>
    <dd class="col-sm-9"><pre>@(Model.AfterJson ?? "")</pre></dd>

    <dt class="col-sm-3">Before JSON</dt>
    <dd class="col-sm-9"><pre>@(Model.BeforeJson ?? "")</pre></dd>
</dl>

@if (ViewBag.Faq != null)
{
    <h5>相關 FAQ</h5>
    <div>@((ARCompletions.Domain.Faq)ViewBag.Faq).Question</div>
    <div class="text-muted">@((ARCompletions.Domain.Faq)ViewBag.Faq).Answer</div>
}

<a asp-action="Index" class="btn btn-secondary">回到列表</a>
