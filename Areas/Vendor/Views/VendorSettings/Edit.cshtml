@model ARCompletions.Domain.Vendor
@{
    ViewData["Title"] = "編輯廠商設定";
}

<h1>編輯廠商設定</h1>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />

    <div class="mb-3">
        <label class="form-label">聯絡人</label>
        <input class="form-control" name="ContactName" value="@Model.ContactName" />
    </div>
    <div class="mb-3">
        <label class="form-label">聯絡信箱</label>
        <input class="form-control" name="ContactEmail" value="@Model.ContactEmail" />
    </div>
    <div class="mb-3">
        <label class="form-label">聯絡電話</label>
        <input class="form-control" name="ContactPhone" value="@Model.ContactPhone" />
    </div>
    <div class="mb-3">
        <label class="form-label">地址</label>
        <input class="form-control" name="Address" value="@Model.Address" />
    </div>
    <div class="mb-3">
        <label class="form-label">備註</label>
        <textarea class="form-control" name="Remark">@Model.Remark</textarea>
    </div>

    <button class="btn btn-primary" type="submit">儲存</button>
    <a asp-action="Index" class="btn btn-secondary">取消</a>
</form>
