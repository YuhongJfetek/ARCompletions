@model IEnumerable<ARCompletions.Domain.AiFaqAnalysisJob>
@{
    ViewData["Title"] = "AI FAQ 分析任務";
}

<h1>AI FAQ 分析任務（廠商）</h1>

<form method="post" asp-action="Trigger">
    @Html.AntiForgeryToken()
    <div class="mb-2">
        <label>起始時間 (Unix 秒，可留空)</label>
        <input type="text" name="dateFrom" class="form-control form-control-sm" />
        <label>結束時間 (Unix 秒，可留空)</label>
        <input type="text" name="dateTo" class="form-control form-control-sm" />
    </div>
    <button class="btn btn-primary" type="submit">觸發分析</button>
</form>

<table class="table table-striped mt-3">
    <thead>
        <tr>
            <th>JobNo</th>
            <th>狀態</th>
            <th>範圍</th>
            <th>候選數</th>
            <th>建立時間</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach(var j in Model)
    {
        <tr>
            <td>@j.JobNo</td>
            <td>@j.Status</td>
            <td>@j.DateFrom - @j.DateTo</td>
            <td>@j.CandidateCount</td>
            <td>@j.CreatedAt</td>
            <td><a asp-action="Details" asp-route-id="@j.Id" class="btn btn-sm btn-secondary">檢視</a></td>
        </tr>
    }
    </tbody>
</table>
