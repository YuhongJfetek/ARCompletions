@model ARCompletions.Areas.Vendor.Models.VendorFaqCandidatesBatchViewModel

@{
    ViewData["Title"] = "批次建立 FAQ";
}

<h2>批次建立 FAQ</h2>

<form asp-action="BatchCreate" method="post">
    <div>
        <label for="category">目標類別</label>
        <select id="category" name="categoryId" class="form-control">
            @foreach (var c in Model.Categories)
            {
                <option value="@c.Value" @(c.Value == Model.SelectedCategoryId ? "selected" : "")>@c.Text</option>
            }
        </select>
    </div>

    <table class="table table-sm mt-3">
        <thead>
            <tr>
                <th></th>
                <th>問題</th>
                <th>回答</th>
                <th>分數</th>
                <th>產生時間</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                <tr>
                    <td><input type="checkbox" name="selectedIds" value="@item.Id" /></td>
                    <td>@item.Question</td>
                    <td>@item.Answer</td>
                    <td>@(item.ConfidenceScore?.ToString("F2") ?? "-")</td>
                    <td>@(DateTimeOffset.FromUnixTimeSeconds(item.GeneratedAt).ToString("g"))</td>
                </tr>
            }
        </tbody>
    </table>

    <button type="submit" class="btn btn-primary">建立 FAQ 並加入 Embedding 隊列</button>
    @Html.AntiForgeryToken()
</form>
