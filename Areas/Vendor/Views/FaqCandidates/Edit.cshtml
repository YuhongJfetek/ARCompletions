@model ARCompletions.Domain.FaqCandidate
@{
    ViewData["Title"] = "檢視候選 QA";
}

<h1>檢視候選 QA</h1>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label class="form-label">問題</label>
        <textarea class="form-control" rows="2" readonly>@Model.Question</textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">建議答案</label>
        <textarea class="form-control" rows="4" readonly>@Model.Answer</textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">目前狀態</label>
        <input class="form-control" value="@Model.Status" readonly />
    </div>
    <div class="mb-3">
        <label class="form-label">更新狀態 (例如 approved / rejected)</label>
        <input name="newStatus" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">指定類別 (選填，只更新建議分類)</label>
        <select name="categoryId" class="form-select" asp-items="(SelectList)ViewBag.CategoryId">
            <option value="">(不變更)</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">儲存</button>
    <a asp-action="Index" class="btn btn-secondary">返回列表</a>
</form>
