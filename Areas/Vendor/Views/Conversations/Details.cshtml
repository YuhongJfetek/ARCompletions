@model ARCompletions.Domain.Conversation
@using ARCompletions.Domain
@{
    ViewData["Title"] = "對話明細 (廠商)";
    var messages = ViewBag.Messages as IEnumerable<ConversationMessage> ?? Enumerable.Empty<ConversationMessage>();
    var inputLogs = ViewBag.InputLogs as IEnumerable<LineBotInputLog> ?? Enumerable.Empty<LineBotInputLog>();
    var outputLogs = ViewBag.OutputLogs as IEnumerable<LineBotOutputLog> ?? Enumerable.Empty<LineBotOutputLog>();
}

<h1>對話明細 (廠商)</h1>

<h4>基本資訊</h4>
<table class="table table-bordered">
    <tr><th>平台</th><td>@Model.Platform</td></tr>
    <tr><th>Channel</th><td>@Model.Channel</td></tr>
    <tr><th>UserId</th><td>@Model.ExternalUserId</td></tr>
    <tr><th>名稱</th><td>@Model.DisplayName</td></tr>
    <tr><th>訊息數</th><td>@Model.MessageCount</td></tr>
    <tr><th>狀態</th><td>@Model.Status</td></tr>
    <tr><th>開始時間</th><td>@Model.StartedAt</td></tr>
    <tr><th>結束時間</th><td>@Model.EndedAt</td></tr>
    <tr><th>最後訊息時間</th><td>@Model.LastMessageAt</td></tr>
</table>

<h4>訊息 (ConversationMessages)</h4>
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>時間</th>
            <th>方向</th>
            <th>類型</th>
            <th>文字</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var m in messages)
    {
        <tr>
            <td>@m.CreatedAt</td>
            <td>@m.Direction</td>
            <td>@m.MessageType</td>
            <td>@m.MessageText</td>
        </tr>
    }
    </tbody>
</table>

<h4>Input Log (LineBotInputLogs)</h4>
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>時間</th>
            <th>MessageId</th>
            <th>類型</th>
            <th>文字</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in inputLogs)
    {
        <tr>
            <td>@l.ReceivedAt</td>
            <td>@l.ExternalMessageId</td>
            <td>@l.MessageType</td>
            <td>@l.MessageText</td>
        </tr>
    }
    </tbody>
</table>

<h4>Output Log (LineBotOutputLogs)</h4>
<table class="table table-sm table-striped">
    <thead>
        <tr>
            <th>時間</th>
            <th>類型</th>
            <th>文字</th>
            <th>來源 FAQ</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var l in outputLogs)
    {
        <tr>
            <td>@l.SentAt</td>
            <td>@l.MessageType</td>
            <td>@l.MessageText</td>
            <td>@l.SourceFaqId</td>
        </tr>
    }
    </tbody>
</table>

<p>
    <a asp-action="Index" class="btn btn-secondary">返回列表</a>
</p>
