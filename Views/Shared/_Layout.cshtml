@{
    var title = ViewData["Title"] ?? "ARCompletions";
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/common.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">ARCompletions</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="切換導覽">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">首頁</a>
                    </li>
                    @if (User?.HasClaim("Role", "Platform") ?? false)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">總部後台</a>
                            <ul class="dropdown-menu" aria-labelledby="adminDropdown">
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="Home" asp-action="Index">管理首頁</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="AiFaqAnalysisJobs" asp-action="Index">AI FAQ 任務</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="FaqLogs" asp-action="Index">FAQ 操作紀錄</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="EmbeddingJobs" asp-action="Index">Embedding 任務</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="MessageApi" asp-action="Index">Message API 設定</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="MessageResults" asp-action="Index">Message Results</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="FaqQueryLogs" asp-action="Index">FAQ Query Logs</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BulkJobs" asp-action="Index">Bulk Jobs</a></li>
                            </ul>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link" asp-area="Vendor" asp-controller="Home" asp-action="Index">廠商後台</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Venues" asp-action="Index">場地 (Venues)</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item me-2">
                            <span class="navbar-text">@User.Identity!.Name</span>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link">登出</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Account" asp-action="Login">總部登入</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Vendor" asp-controller="Account" asp-action="Login">廠商登入</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <footer class="footer mt-5 py-3 bg-light">
        <div class="container">
            <span class="text-muted">© @DateTime.UtcNow.Year ARCompletions — 管理面板與操作介面</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
