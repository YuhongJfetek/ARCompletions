@{
    var title = ViewData["Title"] ?? "ARCompletions";
}
@inject Microsoft.AspNetCore.Authorization.IAuthorizationService AuthorizationService
@{
    var currentArea = Context.Request.RouteValues["area"]?.ToString() ?? string.Empty;
    var currentController = Context.Request.RouteValues["controller"]?.ToString() ?? string.Empty;
    var currentAction = Context.Request.RouteValues["action"]?.ToString() ?? string.Empty;
    string NavActive(bool cond) => cond ? "active" : string.Empty;
}
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/css/common.css" />
    <link rel="stylesheet" href="/css/login.css" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav class="site-navbar navbar navbar-expand-lg navbar-light bg-light">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">ARCompletions</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="切換導覽">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link @(NavActive(currentController == "Home" && string.IsNullOrEmpty(currentArea)))" asp-controller="Home" asp-action="Index">首頁</a>
                    </li>
                    @{ var isPlatform = (User?.Identity?.IsAuthenticated ?? false) && (await AuthorizationService.AuthorizeAsync(User, null, "Platform")).Succeeded; }
                    @if (isPlatform)
                    {
                        // Define controller groups for top-level sections
                        var faqControllers = new[] { "BotFaqItems", "BotFaqAliases" };
                        var embeddingControllers = new[] { "BotEmbeddings" };
                        var messageControllers = new[] { "BotConversations", "BotMessages", "MessageApi" };
                        var systemControllers = new[] { "PlatformUsers", "PlatformRoles", "PlatformPermissions", "SystemSettings", "Audit", "Files", "Groups", "BotStaffUsers", "BotSystemPrompts", "BotConstantsConfig" };

                        bool InGroup(string[] grp) => grp.Contains(currentController);

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(NavActive(InGroup(faqControllers) || InGroup(embeddingControllers) || InGroup(messageControllers)))" href="#" id="botDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">Bot 管理</a>
                            <ul class="dropdown-menu" aria-labelledby="botDropdown">
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BotFaqItems" asp-action="Index">FAQ 管理</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BotFaqAliases" asp-action="Index">FAQ Alias</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BotEmbeddings" asp-action="Index">FAQ Embeddings</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BotConversations" asp-action="Index">會話設定 / 狀態</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BotMessages" asp-action="Routes">訊息路由紀錄</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="BotMessages" asp-action="Events">Incoming Events</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="MessageApi" asp-action="Index">訊息 API 設定</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle @(NavActive(InGroup(systemControllers)))" href="#" id="sysDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">系統管理</a>
                            <ul class="dropdown-menu" aria-labelledby="sysDropdown">
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="PlatformUsers" asp-action="Index">平台帳號</a></li>
                                <li><a class="dropdown-item" asp-area="Admin" asp-controller="SystemSettings" asp-action="Index">系統設定</a></li>
                            </ul>
                        </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link @(NavActive(currentController == "Venues"))" asp-controller="Venues" asp-action="Index">場地</a>
                    </li>
                </ul>
                <ul class="navbar-nav">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item me-2">
                            <span class="navbar-text">@User.Identity!.Name</span>
                        </li>
                        <li class="nav-item">
                            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link">登出</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Account" asp-action="Login">總部登入</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @{ var isLogin = (currentArea == "Admin" && currentController == "Account" && currentAction == "Login"); }

        @await Html.PartialAsync("_Alerts")

        @* Breadcrumb / section header based on controller grouping *@
        @{
            string sectionName = string.Empty;
            if (new[] { "BotFaqItems", "BotFaqAliases" }.Contains(currentController)) sectionName = "FAQ 管理";
            else if (new[] { "BotEmbeddings" }.Contains(currentController)) sectionName = "Embedding 管理";
            else if (new[] { "BotConversations", "BotMessages", "MessageApi" }.Contains(currentController)) sectionName = "訊息管理";
            else if (new[] { "PlatformUsers", "PlatformRoles", "PlatformPermissions", "SystemSettings", "Audit", "Files", "Groups", "BotStaffUsers", "BotSystemPrompts", "BotConstantsConfig" }.Contains(currentController)) sectionName = "系統管理";
        }

        @if (!isLogin)
        {
            <div class="section-header mb-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h4 mb-0">@ViewData["Title"]</h1>
                        @if (!string.IsNullOrEmpty(sectionName))
                        {
                            <small class="text-muted">@("首頁 / " + sectionName)</small>
                        }
                    </div>
                </div>
            </div>

            <div class="main-card">
                @RenderBody()
            </div>
        }
        else
        {
            @RenderBody()
        }
    </div>

    <footer class="footer mt-5 py-3 bg-light">
        <div class="container">
            <span class="text-muted">© @DateTime.UtcNow.Year ARCompletions — 管理面板與操作介面</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
